<%- include('partials/headerForm') %>

<body>

<div class="container">

    <div class="row">

        <div class="col-md-5 col-md-offset-3">

            <div class="card card-signin my-5">

                <div class="card-body">

                    <h3 class="text-center">

                        Verify Email

                    </h3>

                    <p class="text-center">

                        OTP sent to

                        <br>

                        <b><%= email %></b>

                    </p>

                    <form action="/verify-otp" method="POST">

                        <input
                            type="hidden"
                            name="email"
                            value="<%= email %>"
                        >

                        <input
                            class="form-control"
                            name="otp"
                            maxlength="6"
                            placeholder="Enter OTP"
                            required
                        >

                        <br>

                        <button
                            class="btn btn-success btn-block">

                            Verify OTP

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

</body>

</html>