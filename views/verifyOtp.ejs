<!-- ==========================================================
     OTP VERIFICATION
========================================================== -->

<%- include("partials/headerForm") %>

<body class="bg-light">

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-5 col-md-7">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Header -->

                <div class="card-header bg-success text-white text-center py-5 border-0">

                    <div class="otp-icon mx-auto">

                        <i class="fas fa-shield-check"></i>

                    </div>

                    <h2 class="fw-bold mt-4">

                        <%= purpose === "signup"
                            ? "Email Verification"
                            : "Login Verification" %>

                    </h2>

                    <p class="mb-1 opacity-75">

                        We've sent a secure verification code to

                    </p>

                    <strong>

                        <%= email %>

                    </strong>

                </div>

                <!-- Body -->

                <div class="card-body p-5">

                    <% if(typeof error !== "undefined" && error){ %>

                        <div class="alert alert-danger">

                            <i class="fas fa-circle-exclamation me-2"></i>

                            <%= error %>

                        </div>

                    <% } %>

                    <% if(typeof success !== "undefined" && success){ %>

                        <div class="alert alert-success">

                            <i class="fas fa-circle-check me-2"></i>

                            <%= success %>

                        </div>

                    <% } %>

                    <form action="/verify-otp" method="POST">

                        <input
                            type="hidden"
                            name="email"
                            value="<%= email %>">

                        <input
                            type="hidden"
                            name="purpose"
                            value="<%= purpose %>">

                        <div class="mb-4">

                            <label class="form-label fw-semibold">

                                Verification Code

                            </label>

                            <input

                                id="otp"

                                type="text"

                                name="otp"

                                class="form-control otp-input"

                                maxlength="6"

                                minlength="6"

                                pattern="[0-9]{6}"

                                inputmode="numeric"

                                autocomplete="one-time-code"

                                placeholder="000000"

                                required>

                            <small class="text-muted">

                                Enter the 6-digit OTP sent to your email.

                            </small>

                        </div>

                        <button
                            type="submit"
                            class="btn btn-success w-100 btn-lg">

                            <i class="fas fa-check-circle me-2"></i>

                            <%= purpose === "signup"
                                ? "Verify Email"
                                : "Verify & Login" %>

                        </button>

                    </form>

                    <div class="divider">

                        <span>OR</span>

                    </div>

                    <!-- Resend -->

                    <form action="/resend-otp" method="POST">

                        <input
                            type="hidden"
                            name="email"
                            value="<%= email %>">

                        <input
                            type="hidden"
                            name="purpose"
                            value="<%= purpose %>">

                        <button
                            id="resendBtn"
                            type="submit"
                            class="btn btn-outline-primary w-100"
                            disabled>

                            <i class="fas fa-rotate-right me-2"></i>

                            Resend OTP (

                            <span id="timer">

                                60

                            </span>

                            s)

                        </button>

                    </form>

                    <a
                        href="/login"
                        class="btn btn-outline-secondary w-100 mt-3">

                        <i class="fas fa-arrow-left me-2"></i>

                        Back to Login

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

const otpInput = document.getElementById("otp");

otpInput.focus();

otpInput.addEventListener("input",function(){

    this.value=this.value.replace(/\D/g,"");

});

let seconds=60;

const timer=document.getElementById("timer");

const resendBtn=document.getElementById("resendBtn");

const interval=setInterval(()=>{

    seconds--;

    timer.innerText=seconds;

    if(seconds<=0){

        clearInterval(interval);

        resendBtn.disabled=false;

        resendBtn.innerHTML=
        '<i class="fas fa-rotate-right me-2"></i>Resend OTP';

    }

},1000);

</script>

<style>

body{

    background:#f4f7fb;

}

/* Card */

.card{

    border-radius:22px;

}

/* Header */

.card-header{

    background:linear-gradient(135deg,#198754,#39b66a)!important;

}

/* Icon */

.otp-icon{

    width:90px;

    height:90px;

    border-radius:50%;

    background:rgba(255,255,255,.18);

    display:flex;

    justify-content:center;

    align-items:center;

}

.otp-icon i{

    font-size:42px;

    color:#fff;

}

/* OTP Input */

.otp-input{

    height:70px;

    font-size:34px;

    letter-spacing:14px;

    text-align:center;

    font-weight:700;

    border-radius:16px;

}

.otp-input:focus{

    border-color:#198754;

    box-shadow:0 0 0 .2rem rgba(25,135,84,.15);

}

/* Buttons */

.btn{

    min-height:52px;

    border-radius:12px;

    font-weight:600;

}

/* Divider */

.divider{

    display:flex;

    align-items:center;

    margin:30px 0;

}

.divider::before,

.divider::after{

    content:"";

    flex:1;

    height:1px;

    background:#dee2e6;

}

.divider span{

    padding:0 18px;

    color:#6c757d;

    font-size:14px;

    font-weight:600;

}

/* Mobile */

@media(max-width:576px){

    .card-body{

        padding:30px 22px!important;

    }

    .otp-input{

        font-size:28px;

        letter-spacing:10px;

        height:60px;

    }

    .otp-icon{

        width:75px;

        height:75px;

    }

    .otp-icon i{

        font-size:34px;

    }

}

</style>

</body>

</html>