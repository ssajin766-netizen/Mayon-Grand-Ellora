<%- include('partials/headerForm') %>

<body style="background:#f4f7fb;">

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-5 col-md-7">

            <div class="card border-0 shadow-lg otp-card">

                <!-- Header -->

                <div class="card-header otp-header text-center">

                    <div class="otp-icon">

                        <i class="fas fa-shield-alt"></i>

                    </div>

                    <h2 class="mt-3 mb-2">

                        <%= purpose === "signup"
                            ? "Email Verification"
                            : "Login Verification" %>

                    </h2>

                    <p class="mb-0">

                        We've sent a verification code to

                    </p>

                    <strong>

                        <%= email %>

                    </strong>

                </div>

                <!-- Body -->

                <div class="card-body p-4">

                    <% if(typeof error !== "undefined"){ %>

                        <div class="alert alert-danger">

                            <%= error %>

                        </div>

                    <% } %>

                    <% if(typeof success !== "undefined"){ %>

                        <div class="alert alert-success">

                            <%= success %>

                        </div>

                    <% } %>

                    <form action="/verify-otp" method="POST">

                        <input
                            type="hidden"
                            name="email"
                            value="<%= email %>">

                        <input
                            type="hidden"
                            name="purpose"
                            value="<%= purpose %>">

                        <div class="form-group">

                            <label>

                                One-Time Password

                            </label>

                            <input

                                id="otp"

                                type="text"

                                class="form-control otp-input"

                                name="otp"

                                maxlength="6"

                                minlength="6"

                                pattern="[0-9]{6}"

                                inputmode="numeric"

                                autocomplete="one-time-code"

                                placeholder="● ● ● ● ● ●"

                                required>

                            <small class="text-muted">

                                Enter the 6-digit verification code.

                            </small>

                        </div>

                        <button
                            type="submit"
                            class="btn btn-success btn-lg btn-block mt-4">

                            <i class="fas fa-check-circle mr-2"></i>

                            <%= purpose === "signup"
                                ? "Verify Email"
                                : "Verify & Login" %>

                        </button>

                    </form>

                    <div class="divider">

                        <span>OR</span>

                    </div>

                    <form action="/resend-otp" method="POST">

                        <input
                            type="hidden"
                            name="email"
                            value="<%= email %>">

                        <input
                            type="hidden"
                            name="purpose"
                            value="<%= purpose %>">

                        <button

                            id="resendBtn"

                            type="submit"

                            class="btn btn-outline-primary btn-block"

                            disabled>

                            <i class="fas fa-redo-alt mr-2"></i>

                            Resend OTP (

                            <span id="timer">

                                60

                            </span>

                            s)

                        </button>

                    </form>

                    <a

                        href="/login"

                        class="btn btn-outline-secondary btn-block mt-3">

                        <i class="fas fa-arrow-left mr-2"></i>

                        Back to Login

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

const otpInput = document.getElementById("otp");

otpInput.focus();

otpInput.addEventListener("input",function(){

    this.value=this.value.replace(/\D/g,"");

});

let seconds=60;

const timer=document.getElementById("timer");

const resendBtn=document.getElementById("resendBtn");

const interval=setInterval(function(){

    seconds--;

    timer.innerText=seconds;

    if(seconds<=0){

        clearInterval(interval);

        resendBtn.disabled=false;

        resendBtn.innerHTML='<i class="fas fa-redo-alt mr-2"></i>Resend OTP';

    }

},1000);

</script>

<style>

body{

    background:#f4f7fb;

}

/* Card */

.otp-card{

    border-radius:20px;

    overflow:hidden;

}

/* Header */

.otp-header{

    background:linear-gradient(135deg,#198754,#43b76e);

    color:#fff;

    padding:35px;

    border:none;

}

.otp-header p{

    opacity:.9;

}

/* Icon */

.otp-icon{

    width:85px;

    height:85px;

    margin:auto;

    border-radius:50%;

    background:rgba(255,255,255,.18);

    display:flex;

    align-items:center;

    justify-content:center;

}

.otp-icon i{

    font-size:36px;

}

/* OTP */

.otp-input{

    height:65px;

    font-size:30px;

    text-align:center;

    letter-spacing:12px;

    border-radius:15px;

    font-weight:bold;

}

.otp-input:focus{

    border-color:#198754;

    box-shadow:0 0 0 .2rem rgba(25,135,84,.15);

}

/* Buttons */

.btn{

    height:50px;

    border-radius:12px;

    font-weight:600;

}

.btn-success{

    background:#198754;

    border:none;

}

.btn-success:hover{

    background:#157347;

}

/* Divider */

.divider{

    position:relative;

    text-align:center;

    margin:25px 0;

}

.divider span{

    background:#fff;

    padding:0 15px;

    color:#888;

    position:relative;

    z-index:2;

}

.divider::before{

    content:"";

    position:absolute;

    width:100%;

    height:1px;

    background:#ddd;

    left:0;

    top:50%;

}

@media(max-width:576px){

    .otp-input{

        font-size:24px;

        letter-spacing:8px;

    }

}

</style>

</body>

</html>