<%- include("partials/header") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-12">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-info text-white py-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <h3 class="mb-0">

                            <i class="fas fa-history me-2"></i>

                            Login History

                        </h3>

                        <a
                            href="/security"
                            class="btn btn-light">

                            <i class="fas fa-arrow-left me-2"></i>

                            Back

                        </a>

                    </div>

                </div>

                <div class="card-body">

                    <% if(resident.loginHistory && resident.loginHistory.length){ %>

                    <div class="table-responsive">

                        <table class="table table-hover align-middle">

                            <thead class="table-dark">

                                <tr>

                                    <th>#</th>

                                    <th>Date & Time</th>

                                    <th>Login Method</th>

                                    <th>IP Address</th>

                                    <th>Browser</th>

                                    <th>Device</th>

                                    <th>Location</th>

                                    <th>Status</th>

                                </tr>

                            </thead>

                            <tbody>

                                <% resident.loginHistory.slice().reverse().forEach((login,index)=>{ %>

                                <tr>

                                    <td>

                                        <%= index+1 %>

                                    </td>

                                    <td>

                                        <%= login.loginTime ? new Date(login.loginTime).toLocaleString() : "-" %>

                                    </td>

                                    <td>

                                        <% if(login.loginMethod==="Google"){ %>

                                            <span class="badge bg-danger">

                                                <i class="fab fa-google me-1"></i>

                                                Google

                                            </span>

                                        <% } else if(login.loginMethod==="Phone"){ %>

                                            <span class="badge bg-success">

                                                <i class="fas fa-mobile-alt me-1"></i>

                                                Phone OTP

                                            </span>

                                        <% } else { %>

                                            <span class="badge bg-primary">

                                                <i class="fas fa-lock me-1"></i>

                                                Password

                                            </span>

                                        <% } %>

                                    </td>

                                    <td>

                                        <%= login.ip || "-" %>

                                    </td>

                                    <td>

                                        <%= login.browser || "-" %>

                                    </td>

                                    <td>

                                        <%= login.device || "-" %>

                                    </td>

                                    <td>

                                        <%= login.location || "-" %>

                                    </td>

                                    <td>

                                        <% if(login.status==="Success"){ %>

                                            <span class="badge bg-success">

                                                Success

                                            </span>

                                        <% } else { %>

                                            <span class="badge bg-danger">

                                                Failed

                                            </span>

                                        <% } %>

                                    </td>

                                </tr>

                                <% }) %>

                            </tbody>

                        </table>

                    </div>

                    <% } else { %>

                    <div class="text-center py-5">

                        <i class="fas fa-history fa-4x text-secondary mb-3"></i>

                        <h4>No Login History Found</h4>

                        <p class="text-muted">

                            Your login activity will appear here.

                        </p>

                    </div>

                    <% } %>

                    <hr class="my-4">

<div class="d-flex justify-content-between">

    <a href="/security" class="btn btn-secondary">

        <i class="fas fa-arrow-left me-2"></i>

        Back to Security

    </a>

    <form action="/clearLoginHistory" method="POST">

        <button
            type="submit"
            class="btn btn-danger"
            onclick="return confirm('Are you sure you want to clear your login history?');">

            <i class="fas fa-trash me-2"></i>

            Clear Login History

        </button>

    </form>

</div>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include("partials/footer") %>