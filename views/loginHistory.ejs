<!-- ==========================================================
     LOGIN HISTORY
========================================================== -->

<%- include("partials/header") %>

<div class="container py-5">

    <!-- Page Header -->

    <div class="text-center mb-5">

        <div class="security-icon mb-3">

            <i class="fas fa-history"></i>

        </div>

        <h2 class="fw-bold">

            Login History

        </h2>

        <p class="text-muted">

            Review all recent login activity for your account.

        </p>

    </div>

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-header bg-primary text-white py-3">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <h4 class="mb-0">

                    <i class="fas fa-clock me-2"></i>

                    Recent Login Activity

                </h4>

                <a
                    href="/security"
                    class="btn btn-light btn-sm">

                    <i class="fas fa-arrow-left me-2"></i>

                    Back

                </a>

            </div>

        </div>

        <div class="card-body">

            <% if(resident.loginHistory && resident.loginHistory.length){ %>

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>#</th>

                            <th>Date & Time</th>

                            <th>Method</th>

                            <th>IP Address</th>

                            <th>Browser</th>

                            <th>Device</th>

                            <th>Location</th>

                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% resident.loginHistory.slice().reverse().forEach((login,index)=>{ %>

                        <tr>

                            <td>

                                <strong><%= index+1 %></strong>

                            </td>

                            <td>

                                <%= login.loginTime ? new Date(login.loginTime).toLocaleString() : "-" %>

                            </td>

                            <td>

                                <% if(login.loginMethod==="Google"){ %>

                                    <span class="badge bg-danger">

                                        <i class="fab fa-google me-1"></i>

                                        Google

                                    </span>

                                <% } else if(login.loginMethod==="Phone"){ %>

                                    <span class="badge bg-success">

                                        <i class="fas fa-mobile-alt me-1"></i>

                                        Phone OTP

                                    </span>

                                <% } else { %>

                                    <span class="badge bg-primary">

                                        <i class="fas fa-lock me-1"></i>

                                        Password

                                    </span>

                                <% } %>

                            </td>

                            <td>

                                <code>

                                    <%= login.ip || "-" %>

                                </code>

                            </td>

                            <td>

                                <%= login.browser || "-" %>

                            </td>

                            <td>

                                <%= login.device || "-" %>

                            </td>

                            <td>

                                <% if(login.location){ %>

                                    <i class="fas fa-map-marker-alt text-danger me-1"></i>

                                    <%= login.location %>

                                <% } else { %>

                                    -

                                <% } %>

                            </td>

                            <td>

                                <% if(login.status==="Success"){ %>

                                    <span class="badge bg-success">

                                        <i class="fas fa-check-circle me-1"></i>

                                        Success

                                    </span>

                                <% } else { %>

                                    <span class="badge bg-danger">

                                        <i class="fas fa-times-circle me-1"></i>

                                        Failed

                                    </span>

                                <% } %>

                            </td>

                        </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

            <% } else { %>

            <div class="text-center py-5">

                <i class="fas fa-history fa-5x text-secondary mb-4"></i>

                <h3>

                    No Login History

                </h3>

                <p class="text-muted">

                    Your recent login activity will appear here.

                </p>

            </div>

            <% } %>

        </div>

        <div class="card-footer bg-light">

            <div class="d-flex justify-content-between flex-wrap gap-3">

                <a
                    href="/security"
                    class="btn btn-secondary">

                    <i class="fas fa-arrow-left me-2"></i>

                    Back to Security

                </a>

                <% if(resident.loginHistory && resident.loginHistory.length){ %>

                <form
                    action="/clearLoginHistory"
                    method="POST">

                    <button
                        type="submit"
                        class="btn btn-danger"
                        onclick="return confirm('Are you sure you want to clear all login history?');">

                        <i class="fas fa-trash-alt me-2"></i>

                        Clear Login History

                    </button>

                </form>

                <% } %>

            </div>

        </div>

    </div>

</div>

<style>

.security-icon{

    width:90px;

    height:90px;

    margin:auto;

    border-radius:50%;

    background:#eaf4ff;

    display:flex;

    justify-content:center;

    align-items:center;

    box-shadow:0 10px 30px rgba(13,110,253,.15);

}

.security-icon i{

    font-size:38px;

    color:#0d6efd;

}

.table td{

    vertical-align:middle;

}

.table tbody tr:hover{

    background:#f8fbff;

}

.card{

    overflow:hidden;

}

.badge{

    padding:.6em .9em;

    font-size:.8rem;

}

code{

    color:#dc3545;

    font-size:.9rem;

}

@media(max-width:768px){

    .card-header{

        text-align:center;

    }

    .card-header .btn{

        margin-top:15px;

    }

    .card-footer .d-flex{

        flex-direction:column;

    }

    .card-footer .btn{

        width:100%;

    }

}

</style>

<%- include("partials/footer") %>