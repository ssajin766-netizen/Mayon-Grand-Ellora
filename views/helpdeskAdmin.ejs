<!-- ==========================================================
     COMMUNITY COMPLAINTS (ADMIN)
========================================================== -->

<%- include("partials/header") %>

<div class="container py-4">

    <!-- ==========================================
         Header
    =========================================== -->

    <div class="text-center mb-5">

        <h2 class="fw-bold">

            <i class="fas fa-users-cog text-danger me-2"></i>

            Community Complaints

        </h2>

        <p class="text-muted">

            Review and manage complaints submitted by society residents.

        </p>

    </div>

    <!-- ==========================================
         Raise Complaint
    =========================================== -->

    <div class="text-center mb-5">

        <a
            href="/complaint"
            class="btn btn-danger btn-lg rounded-pill shadow-sm px-4">

            <i class="fas fa-plus-circle me-2"></i>

            Raise Complaint

        </a>

    </div>

    <!-- ==========================================
         Complaints
    =========================================== -->

    <form action="/closeTicket" method="POST">

        <div class="row g-4">

        <% let complaintFound = false; %>

        <% users.forEach((user)=>{ %>

            <% user.complaints.forEach((complaint,index)=>{ %>

                <% if(complaint.status==="open"){ %>

                <% complaintFound = true; %>

                <div class="col-lg-6">

                    <div class="card complaint-card border-0 shadow-sm h-100">

                        <div class="card-body">

                            <!-- Header -->

                            <div class="d-flex justify-content-between">

                                <div>

                                    <h5 class="fw-bold mb-1">

                                        <i class="fas fa-tools text-danger me-2"></i>

                                        <%= complaint.category %>

                                    </h5>

                                    <small class="text-muted">

                                        <i class="far fa-calendar-alt me-1"></i>

                                        <%= complaint.date %>

                                    </small>

                                </div>

                                <span class="badge bg-success">

                                    Open

                                </span>

                            </div>

                            <hr>

                            <!-- Resident -->

                            <div class="mb-3">

                                <strong>

                                    Resident

                                </strong>

                                <p class="mb-0 text-muted">

                                    <%= user.firstName %>

                                    <%= user.lastName %>

                                </p>

                            </div>

                            <!-- Flat -->

                            <div class="mb-3">

                                <strong>

                                    Flat Number

                                </strong>

                                <p class="mb-0">

                                    <span class="badge bg-primary">

                                        <%= user.flatNumber %>

                                    </span>

                                </p>

                            </div>

                            <!-- Complaint Type -->

                            <div class="mb-3">

                                <strong>

                                    Complaint Type

                                </strong>

                                <p class="mb-0 text-muted">

                                    <%= complaint.type %>

                                </p>

                            </div>

                            <!-- Description -->

                            <div class="mb-4">

                                <strong>

                                    Description

                                </strong>

                                <p class="complaint-text">

                                    <%= complaint.description %>

                                </p>

                            </div>

                            <!-- Close -->

                            <button

                                type="submit"

                                class="btn btn-success rounded-pill px-4"

                                name="ticket[<%= user._id %>]"

                                value="<%= index %>">

                                <i class="fas fa-check-circle me-2"></i>

                                Close Ticket

                            </button>

                        </div>

                    </div>

                </div>

                <% } %>

            <% }) %>

        <% }) %>

        </div>

    </form>

    <!-- ==========================================
         Empty State
    =========================================== -->

    <% if(!complaintFound){ %>

    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body text-center py-5">

            <i class="fas fa-check-circle fa-5x text-success mb-4"></i>

            <h3>

                No Open Complaints

            </h3>

            <p class="text-muted">

                All complaints have been resolved.

            </p>

        </div>

    </div>

    <% } %>

</div>

<style>

/* ==========================================
   Complaint Cards
========================================== */

.complaint-card{

    border-radius:20px;

    transition:.35s;

    overflow:hidden;

}

.complaint-card:hover{

    transform:translateY(-8px);

    box-shadow:0 20px 40px rgba(0,0,0,.15)!important;

}

.complaint-card .card-body{

    padding:28px;

}

.complaint-text{

    color:#495057;

    line-height:1.8;

    white-space:pre-wrap;

}

.badge{

    font-size:13px;

    padding:8px 14px;

}

.card hr{

    margin:18px 0;

}

.btn-success{

    font-weight:600;

}

@media(max-width:768px){

    .complaint-card .card-body{

        padding:22px;

    }

}

</style>

<%- include("partials/footer") %>