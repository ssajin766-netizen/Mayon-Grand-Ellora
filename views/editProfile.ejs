<!-- Security Settings -->

<hr class="my-4">

<div class="col-sm-12">

    <h5>

        Security Settings

    </h5>

</div>

<!-- Email -->

<div class="col-sm-12 col-lg-12 mt-3">

    <b>Email Address :</b>

</div>

<div class="col-sm-12 col-lg-12 mt-1">

    <input

        class="form-control"

        value="<%= resident.username %>"

        readonly

    >

</div>

<!-- Email Verification -->

<div class="col-sm-12 col-lg-12 mt-3">

    <b>Email Verification :</b>

</div>

<div class="col-sm-12 col-lg-12 mt-1">

    <% if(resident.isEmailVerified){ %>

        <span class="badge badge-success">

            Verified

        </span>

    <% } else { %>

        <span class="badge badge-danger">

            Not Verified

        </span>

    <% } %>

</div>

<!-- Phone Verification -->

<div class="col-sm-12 col-lg-12 mt-3">

    <b>Phone Verification :</b>

</div>

<div class="col-sm-12 col-lg-12 mt-1">

    <% if(resident.isPhoneVerified){ %>

        <span class="badge badge-success">

            Verified

        </span>

    <% } else { %>

        <span class="badge badge-warning">

            Not Verified

        </span>

    <% } %>

</div>

<!-- Login Method -->

<div class="col-sm-12 col-lg-12 mt-3">

    <b>Preferred Login :</b>

</div>

<div class="col-sm-12 col-lg-12 mt-1">

    <select

        name="loginType"

        class="form-control"

    >

        <option
            value="password"
            <%= resident.loginType === "password" ? "selected" : "" %>>

            Email & Password

        </option>

        <option
            value="google"
            <%= resident.loginType === "google" ? "selected" : "" %>>

            Google

        </option>

        <option
            value="phone"
            <%= resident.loginType === "phone" ? "selected" : "" %>>

            Phone (SMS OTP)

        </option>

    </select>

</div>

<!-- Two Factor -->

<div class="col-sm-12 col-lg-12 mt-4">

    <div class="custom-control custom-switch">

        <input

            type="checkbox"

            class="custom-control-input"

            id="twoFactor"

            name="twoFactorEnabled"

            <%= resident.twoFactorEnabled ? "checked" : "" %>

        >

        <label

            class="custom-control-label"

            for="twoFactor"

        >

            Enable Two-Step Verification (Email OTP)

        </label>

    </div>

</div>