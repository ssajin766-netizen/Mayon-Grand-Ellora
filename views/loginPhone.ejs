<!-- ==========================================================
     PHONE LOGIN
========================================================== -->

<%- include("partials/headerForm") %>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/css/intlTelInput.css">

<link
href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
rel="stylesheet">

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-5 col-md-7">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- Header -->

                <div class="card-header bg-success text-white text-center py-4 border-0">

                    <div class="phone-icon">

                        <i class="fas fa-mobile-alt"></i>

                    </div>

                    <h2 class="fw-bold mt-3">

                        Phone Login

                    </h2>

                    <p class="mb-0 opacity-75">

                        Sign in securely using OTP verification.

                    </p>

                </div>

                <!-- Body -->

                <div class="card-body p-5">

                    <% if(success && success.length){ %>

                        <div class="alert alert-success">

                            <%= success %>

                        </div>

                    <% } %>

                    <% if(error && error.length){ %>

                        <div class="alert alert-danger">

                            <%= error %>

                        </div>

                    <% } %>

                    <form
                        id="phoneLoginForm"
                        action="/phone/send"
                        method="POST">

                        <div class="mb-4">

                            <label class="form-label fw-semibold">

                                Mobile Number

                            </label>

                            <input

                                id="phone"

                                type="tel"

                                autocomplete="tel"

                                class="form-control"

                                required>

                            <input

                                type="hidden"

                                id="phoneNumber"

                                name="phoneNumber">

                            <small class="text-muted">

                                Select your country code and enter your mobile number.

                            </small>

                        </div>

                        <button

                            id="submitBtn"

                            type="submit"

                            class="btn btn-success w-100">

                            <i class="fas fa-paper-plane me-2"></i>

                            Send OTP

                        </button>

                    </form>

                    <div class="divider">

                        <span>OR</span>

                    </div>

                    <a
                        href="/login"
                        class="btn btn-outline-dark w-100">

                        <i class="fas fa-envelope me-2"></i>

                        Continue with Email

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/intlTelInput.min.js"></script>

<script>

const phoneInput = document.querySelector("#phone");
const hiddenInput = document.querySelector("#phoneNumber");
const form = document.getElementById("phoneLoginForm");
const btn = document.getElementById("submitBtn");

const iti = window.intlTelInput(phoneInput,{

    initialCountry:"in",

    preferredCountries:[
        "in",
        "us",
        "gb",
        "ae",
        "sg",
        "my",
        "lk"
    ],

    separateDialCode:true,

    nationalMode:false,

    autoPlaceholder:"aggressive",

    formatOnDisplay:true,

    loadUtils:()=>import(
"https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/utils.js")

});

form.addEventListener("submit",function(e){

    e.preventDefault();

    if(phoneInput.value.trim()===""){

        phoneInput.focus();

        return;

    }

    hiddenInput.value = iti.getNumber();

    btn.disabled = true;

    btn.innerHTML = `
        <span class="spinner-border spinner-border-sm me-2"></span>
        Sending OTP...
    `;

    this.submit();

});

</script>

<style>

body{

    background:#f4f7fb;

    font-family:'Inter',sans-serif;

}

.phone-icon{

    width:90px;

    height:90px;

    margin:auto;

    border-radius:50%;

    background:#ffffff22;

    display:flex;

    justify-content:center;

    align-items:center;

}

.phone-icon i{

    font-size:42px;

    color:#fff;

}

.card{

    border-radius:24px;

}

.form-control{

    height:56px;

    border-radius:14px;

    border:2px solid #e5e7eb;

}

.form-control:focus{

    border-color:#198754;

    box-shadow:0 0 0 .2rem rgba(25,135,84,.15);

}

.iti{

    width:100%;

}

.iti input{

    width:100%!important;

    height:56px!important;

    border-radius:14px;

}

.iti__country-list{

    border-radius:14px;

    box-shadow:0 10px 25px rgba(0,0,0,.12);

    z-index:99999;

}

.btn{

    height:52px;

    border-radius:14px;

    font-weight:600;

}

.divider{

    display:flex;

    align-items:center;

    margin:28px 0;

}

.divider::before,

.divider::after{

    content:"";

    flex:1;

    height:1px;

    background:#dee2e6;

}

.divider span{

    padding:0 15px;

    color:#6c757d;

    font-size:14px;

}

@media(max-width:768px){

    .card-body{

        padding:30px 22px;

    }

}

</style>

<%- include("partials/footer") %>