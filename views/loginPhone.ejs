<%- include("partials/header") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-5">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-success text-white text-center py-4">

                    <h2 class="mb-0">

                        <i class="fas fa-mobile-alt me-2"></i>

                        Phone Login

                    </h2>

                    <p class="mb-0 mt-2">

                        Login securely using your mobile number

                    </p>

                </div>

                <div class="card-body p-5">

                    <% if(success && success.length){ %>

                        <div class="alert alert-success">

                            <%= success %>

                        </div>

                    <% } %>

                    <% if(error && error.length){ %>

                        <div class="alert alert-danger">

                            <%= error %>

                        </div>

                    <% } %>

                    <form id="phoneLoginForm" action="/phone/send" method="POST">

                        <div class="mb-4">

                            <label class="form-label fw-bold">

                                Mobile Number

                            </label>

                            <!-- Visible Phone Input -->

                            <input

                                id="phone"

                                type="tel"

                                class="form-control"

                                required

                            >

                            <!-- Hidden Input Submitted to Server -->

                            <input

                                type="hidden"

                                id="phoneNumber"

                                name="phoneNumber"

                            >

                            <small class="text-muted">

                                Select your country and enter your mobile number.

                            </small>

                        </div>

                        <button

                            type="submit"

                            class="btn btn-success w-100 btn-lg">

                            <i class="fas fa-paper-plane me-2"></i>

                            Send OTP

                        </button>

                    </form>

                    <hr class="my-4">

                    <div class="text-center">

                        <a

                            href="/login"

                            class="btn btn-outline-secondary">

                            <i class="fas fa-arrow-left me-2"></i>

                            Back to Login

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- International Phone Input -->

<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/intlTelInput.min.js"></script>

<script>

const input = document.querySelector("#phone");

const iti = window.intlTelInput(input, {

    initialCountry: "in",

    preferredCountries: [

        "in",

        "us",

        "gb",

        "ae",

        "sg",

        "my",

        "lk"

    ],

    separateDialCode: true,

    autoPlaceholder: "aggressive",

    nationalMode: false,

    formatOnDisplay: true,

    utilsScript:

    "https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/utils.js"

});

document
.getElementById("phoneLoginForm")
.addEventListener("submit", function(e){

    if(!iti.isValidNumber()){

        e.preventDefault();

        alert("Please enter a valid mobile number.");

        return;

    }

    document.getElementById("phoneNumber").value =
        iti.getNumber();

});

</script>

<style>

.iti{

    width:100%;

}

.iti input{

    width:100% !important;

    height:46px;

    font-size:16px;

}

</style>

<%- include("partials/footer") %>