<%- include("partials/header") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-md-6 col-lg-5">

            <div class="panel panel-default shadow">

                <div class="panel-heading text-center bg-success text-white">

                    <h2>

                        <i class="fas fa-mobile-alt"></i>

                        Phone Login

                    </h2>

                    <p>

                        Login securely using your mobile number

                    </p>

                </div>

                <div class="panel-body">

                    <% if(success && success.length){ %>

                        <div class="alert alert-success">

                            <%= success %>

                        </div>

                    <% } %>

                    <% if(error && error.length){ %>

                        <div class="alert alert-danger">

                            <%= error %>

                        </div>

                    <% } %>

                    <form
                        id="phoneLoginForm"
                        action="/phone/send"
                        method="POST">

                        <div class="form-group">

                            <label>

                                Mobile Number

                            </label>

                            <input
                                id="phone"
                                type="tel"
                                class="form-control"
                                autocomplete="tel"
                                required>

                            <input
                                type="hidden"
                                id="phoneNumber"
                                name="phoneNumber">

                            <small class="text-muted">

                                Select your country and enter your mobile number.

                            </small>

                        </div>

                        <button
                            type="submit"
                            class="btn btn-success btn-lg btn-block">

                            <i class="fas fa-paper-plane"></i>

                            Send OTP

                        </button>

                    </form>

                    <hr>

                    <div class="text-center">

                        <a
                            href="/login"
                            class="btn btn-default">

                            <i class="fas fa-arrow-left"></i>

                            Back to Login

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/intlTelInput.min.js"></script>

<script>

const phoneInput = document.querySelector("#phone");

const hiddenInput = document.querySelector("#phoneNumber");

const iti = window.intlTelInput(phoneInput, {

    initialCountry: "in",

    preferredCountries: [

        "in",

        "us",

        "gb",

        "ae",

        "sg",

        "my",

        "lk"

    ],

    separateDialCode: true,

    autoPlaceholder: "polite",

    formatOnDisplay: true,

    strictMode: true,

    loadUtils: () =>
        import("https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/utils.js")

});

document
.getElementById("phoneLoginForm")
.addEventListener("submit", function(e){

    e.preventDefault();

    if(phoneInput.value.trim()===""){

        alert("Please enter your mobile number.");

        phoneInput.focus();

        return;

    }

    if(!iti.isValidNumber()){

        alert("Please enter a valid mobile number.");

        phoneInput.focus();

        return;

    }

    hiddenInput.value = iti.getNumber();

    console.log(hiddenInput.value);

    this.submit();

});

</script>

<style>

.panel{

    border-radius:15px;

}

.panel-heading{

    border-radius:15px 15px 0 0;

}

.iti{

    width:100%;

}

.iti input{

    width:100% !important;

    height:46px;

    font-size:16px;

}

</style>

<%- include("partials/footer") %>