<%- include("partials/header") %>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/css/intlTelInput.css">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
rel="stylesheet">

<div class="login-wrapper">

    <div class="login-card">

        <div class="text-center mb-4">

            <div class="logo-circle">

                <i class="fab fa-whatsapp"></i>

            </div>

            <h2>

                Continue with Phone

            </h2>

            <p>

                Enter your mobile number to receive a secure verification code.

            </p>

        </div>

        <% if(success && success.length){ %>

            <div class="alert alert-success">

                <%= success %>

            </div>

        <% } %>

        <% if(error && error.length){ %>

            <div class="alert alert-danger">

                <%= error %>

            </div>

        <% } %>

        <form
            id="phoneLoginForm"
            action="/phone/send"
            method="POST">

            <div class="mb-4">

                <label class="form-label">

                    Mobile Number

                </label>

                <input
                    id="phone"
                    type="tel"
                    autocomplete="tel"
                    class="form-control"
                    required>

                <input
                    type="hidden"
                    id="phoneNumber"
                    name="phoneNumber">

            </div>

            <button
                id="submitBtn"
                type="submit"
                class="btn btn-success w-100">

                <i class="fas fa-paper-plane me-2"></i>

                Send OTP

            </button>

        </form>

        <div class="divider">

            <span>OR</span>

        </div>

        <a
            href="/login"
            class="btn btn-outline-secondary w-100">

            <i class="fas fa-arrow-left me-2"></i>

            Back to Email Login

        </a>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/intlTelInput.min.js"></script>

<script>

const phoneInput=document.querySelector("#phone");
const hiddenInput=document.querySelector("#phoneNumber");
const form=document.getElementById("phoneLoginForm");
const btn=document.getElementById("submitBtn");

const iti=window.intlTelInput(phoneInput,{

    initialCountry:"in",

    preferredCountries:[
        "in",
        "us",
        "gb",
        "ae",
        "sg",
        "my",
        "lk"
    ],

    separateDialCode:true,

    nationalMode:false,

    autoPlaceholder:"aggressive",

    formatOnDisplay:true,

    loadUtils:()=>import(
"https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/utils.js")

});

form.addEventListener("submit",function(e){

    e.preventDefault();

    if(phoneInput.value.trim()===""){

        phoneInput.focus();

        return;

    }

    hiddenInput.value=iti.getNumber();

    btn.disabled=true;

    btn.innerHTML=`
    <span class="spinner-border spinner-border-sm me-2"></span>
    Sending OTP...
    `;

    this.submit();

});

</script>

<style>

body{

    background:#f3f5f7;

    font-family:'Inter',sans-serif;

}

.login-wrapper{

    min-height:90vh;

    display:flex;

    align-items:center;

    justify-content:center;

    padding:30px;

}

.login-card{

    width:100%;

    max-width:430px;

    background:#fff;

    border-radius:24px;

    padding:40px;

    box-shadow:

        0 15px 45px rgba(0,0,0,.08);

    animation:fadeUp .45s ease;

}

.logo-circle{

    width:90px;

    height:90px;

    margin:auto;

    border-radius:50%;

    background:#25D366;

    display:flex;

    align-items:center;

    justify-content:center;

    color:#fff;

    font-size:42px;

    box-shadow:

        0 10px 25px rgba(37,211,102,.3);

}

h2{

    font-weight:700;

    margin-top:25px;

}

p{

    color:#777;

    margin-bottom:25px;

}

.form-label{

    font-weight:600;

}

.form-control{

    height:58px;

    border-radius:16px;

    border:2px solid #e5e7eb;

    font-size:16px;

}

.form-control:focus{

    border-color:#25D366;

    box-shadow:0 0 0 .2rem rgba(37,211,102,.15);

}

.iti{

    width:100%;

}

.iti input{

    width:100%!important;

    height:58px!important;

}

.btn{

    height:56px;

    border-radius:16px;

    font-weight:600;

}

.btn-success{

    background:#25D366;

    border:none;

}

.btn-success:hover{

    background:#1ebe5d;

}

.divider{

    display:flex;

    align-items:center;

    margin:28px 0;

}

.divider::before,

.divider::after{

    content:"";

    flex:1;

    height:1px;

    background:#ddd;

}

.divider span{

    padding:0 15px;

    color:#999;

}

@keyframes fadeUp{

    from{

        opacity:0;

        transform:translateY(25px);

    }

    to{

        opacity:1;

        transform:none;

    }

}

@media(max-width:576px){

    .login-card{

        padding:28px;

    }

}

</style>

<%- include("partials/footer") %>