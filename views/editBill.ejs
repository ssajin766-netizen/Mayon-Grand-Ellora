<%- include('partials/header') %>

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <i class="fas fa-file-invoice-dollar text-primary fa-3x mb-3"></i>

                        <h2 class="fw-bold">

                            Edit Maintenance Bill

                        </h2>

                        <p class="text-muted">

                            Update the monthly maintenance charges.

                        </p>

                    </div>

                    <form action="/editBill" method="POST">

                        <!-- Society Charges -->

                        <div class="mb-4">

                            <label class="form-label fw-semibold">

                                Society Charges

                            </label>

                            <input
                                type="number"
                                class="form-control"
                                name="societyCharges"
                                value="<%= maintenanceBill.societyCharges %>"
                                required>

                        </div>

                        <!-- Repairs -->

                        <div class="mb-4">

                            <label class="form-label fw-semibold">

                                Repairs & Maintenance

                            </label>

                            <input
                                type="number"
                                class="form-control"
                                name="repairsAndMaintenance"
                                value="<%= maintenanceBill.repairsAndMaintenance %>"
                                required>

                        </div>

                        <!-- Sinking Fund -->

                        <div class="mb-4">

                            <label class="form-label fw-semibold">

                                Sinking Fund

                            </label>

                            <input
                                type="number"
                                class="form-control"
                                name="sinkingFund"
                                value="<%= maintenanceBill.sinkingFund %>"
                                required>

                        </div>

                        <!-- Water -->

                        <div class="mb-4">

                            <label class="form-label fw-semibold">

                                Water Charges

                            </label>

                            <input
                                type="number"
                                class="form-control"
                                name="waterCharges"
                                value="<%= maintenanceBill.waterCharges %>"
                                required>

                        </div>

                        <!-- Insurance -->

                        <div class="mb-4">

                            <label class="form-label fw-semibold">

                                Insurance Charges

                            </label>

                            <input
                                type="number"
                                class="form-control"
                                name="insuranceCharges"
                                value="<%= maintenanceBill.insuranceCharges %>"
                                required>

                        </div>

                        <!-- Parking -->

                        <div class="mb-4">

                            <label class="form-label fw-semibold">

                                Parking Charges

                            </label>

                            <input
                                type="number"
                                class="form-control"
                                name="parkingCharges"
                                value="<%= maintenanceBill.parkingCharges %>"
                                required>

                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">

                            <a
                                href="/bill"
                                class="btn btn-outline-secondary">

                                <i class="fas fa-times me-2"></i>

                                Cancel

                            </a>

                            <button
                                type="submit"
                                class="btn btn-primary">

                                <i class="fas fa-save me-2"></i>

                                Save Changes

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include('partials/footer') %>