<!-- Personal + Society information -->
<%- include('partials/header') %>

<div class="container mt-4">

    <div class="text-center mb-4">

        <a
            href="/editProfile"
            class="btn btn-danger px-4"
            style="border-radius:30px;"
        >

            <i class="fas fa-user-edit"></i>

            Edit Profile

        </a>

    </div>

    <div class="card shadow border-0">

        <div class="card-body p-5">

            <h2 class="font-weight-bold">

                My Profile

            </h2>

            <hr>

            <!-- Personal Information -->

            <h5 class="text-danger mb-4">

                Personal Information

            </h5>

            <table class="table table-borderless">

                <tr>

                    <th width="35%">Name</th>

                    <td>

                        <%= resident.firstName %>

                        <%= resident.lastName %>

                    </td>

                </tr>

                <tr>

                    <th>Email</th>

                    <td>

                        <%= resident.username %>

                    </td>

                </tr>

                <tr>

                    <th>Phone</th>

                    <td>

                        <%= resident.phoneNumber || "-" %>

                    </td>

                </tr>

                <tr>

                    <th>Flat Number</th>

                    <td>

                        <%= resident.flatNumber %>

                    </td>

                </tr>

            </table>

            <hr>

            <!-- Security -->

            <h5 class="text-danger mb-4">

                Security

            </h5>

            <table class="table table-borderless">

                <tr>

                    <th width="35%">

                        Email Verified

                    </th>

                    <td>

                        <% if(resident.isEmailVerified){ %>

                            <span class="badge badge-success">

                                Verified

                            </span>

                        <% } else { %>

                            <span class="badge badge-danger">

                                Not Verified

                            </span>

                        <% } %>

                    </td>

                </tr>

                <tr>

                    <th>

                        Phone Verified

                    </th>

                    <td>

                        <% if(resident.isPhoneVerified){ %>

                            <span class="badge badge-success">

                                Verified

                            </span>

                        <% } else { %>

                            <span class="badge badge-warning">

                                Pending

                            </span>

                        <% } %>

                    </td>

                </tr>

                <tr>

                    <th>

                        Login Method

                    </th>

                    <td>

                        <%= resident.loginType %>

                    </td>

                </tr>

                <tr>

                    <th>

                        Two-Step Verification

                    </th>

                    <td>

                        <% if(resident.twoFactorEnabled){ %>

                            <span class="badge badge-success">

                                Enabled

                            </span>

                        <% } else { %>

                            <span class="badge badge-secondary">

                                Disabled

                            </span>

                        <% } %>

                    </td>

                </tr>

                <tr>

                    <th>

                        Last Login

                    </th>

                    <td>

                        <%= resident.lastLogin
                            ? resident.lastLogin.toLocaleString()
                            : "Never" %>

                    </td>

                </tr>

            </table>

            <hr>

            <!-- Society -->

            <h5 class="text-danger mb-4">

                Society Information

            </h5>

            <table class="table table-borderless">

                <tr>

                    <th width="35%">

                        Society Name

                    </th>

                    <td>

                        <%= society.societyName %>

                    </td>

                </tr>

                <tr>

                    <th>

                        Address

                    </th>

                    <td>

                        <%= society.societyAddress.address %>

                    </td>

                </tr>

                <tr>

                    <th>

                        City

                    </th>

                    <td>

                        <%= society.societyAddress.city %>

                    </td>

                </tr>

                <tr>

                    <th>

                        District

                    </th>

                    <td>

                        <%= society.societyAddress.district %>

                    </td>

                </tr>

                <tr>

                    <th>

                        Postal Code

                    </th>

                    <td>

                        <%= society.societyAddress.postalCode %>

                    </td>

                </tr>

            </table>

        </div>

    </div>

</div>

<%- include('partials/footer') %>