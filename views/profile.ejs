<div class="row mb-4">

    <div class="col-lg-12">

        <div class="card shadow-lg border-0 rounded-4">

            <div class="card-body p-5">

                <div class="row align-items-center">

                    <!-- =========================
                         PROFILE IMAGE
                    ========================== -->

                    <div class="col-lg-3 text-center">

                        <form
                            action="/profile/upload"
                            method="POST"
                            enctype="multipart/form-data"
                            id="profileUploadForm">

                            <input
                                type="file"
                                id="profileImage"
                                name="profileImage"
                                accept="image/*"
                                style="display:none">

                            <div
                                class="profile-photo-wrapper"
                                onclick="document.getElementById('profileImage').click()">

                                <img
                                    id="profilePreview"
                                    src="<%= resident.profileImage || '/images/default-avatar.png' %>"
                                    class="profile-photo"
                                    alt="Profile">

                                <div class="camera-overlay">

                                    <i class="fas fa-camera"></i>

                                </div>

                            </div>

                            <button
                                id="uploadBtn"
                                class="btn btn-success mt-3 px-4"
                                style="display:none">

                                <i class="fas fa-upload me-2"></i>

                                Save Photo

                            </button>

                        </form>

                    </div>

                    <!-- =========================
                         USER DETAILS
                    ========================== -->

                    <div class="col-lg-6 mt-4 mt-lg-0">

                        <h2 class="fw-bold mb-2">

                            <%= resident.firstName %>

                            <%= resident.lastName %>

                        </h2>

                        <p class="text-muted mb-2">

                            <i class="fas fa-envelope me-2 text-primary"></i>

                            <%= resident.username %>

                        </p>

                        <p class="text-muted mb-3">

                            <i class="fas fa-home me-2 text-success"></i>

                            Flat <%= resident.flatNumber %>

                        </p>

                        <div class="d-flex flex-wrap gap-2">

                            <% if(resident.isEmailVerified){ %>

                                <span class="badge bg-success">

                                    <i class="fas fa-check-circle me-1"></i>

                                    Email Verified

                                </span>

                            <% } %>

                            <% if(resident.isPhoneVerified){ %>

                                <span class="badge bg-primary">

                                    <i class="fas fa-mobile-alt me-1"></i>

                                    Phone Verified

                                </span>

                            <% } %>

                            <% if(resident.isAdmin){ %>

                                <span class="badge bg-danger">

                                    Administrator

                                </span>

                            <% } else { %>

                                <span class="badge bg-info text-dark">

                                    Resident

                                </span>

                            <% } %>

                        </div>

                    </div>

                    <!-- =========================
                         ACTION BUTTONS
                    ========================== -->

                    <div class="col-lg-3 text-lg-end mt-4 mt-lg-0">

                        <a
                            href="/editProfile"
                            class="btn btn-primary w-100 mb-3">

                            <i class="fas fa-user-edit me-2"></i>

                            Edit Profile

                        </a>

                        <a
                            href="/security"
                            class="btn btn-outline-danger w-100">

                            <i class="fas fa-user-shield me-2"></i>

                            Security

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- ==========================================================
     INFORMATION SECTION
========================================================== -->

<div class="row g-4 mt-4">

    <!-- Personal Information -->

    <div class="col-lg-6">

    <div class="card shadow-sm border-0 rounded-4 h-100">

        <div class="card-body p-4">

            <div class="d-flex align-items-center mb-4">

                <div class="icon-box bg-primary">

                    <i class="fas fa-user text-white"></i>

                </div>

                <div class="ms-3">

                    <h4 class="fw-bold mb-0">

                        Personal Information

                    </h4>

                    <small class="text-muted">

                        Your account details

                    </small>

                </div>

            </div>

            <div class="profile-item">

                <span>

                    <i class="fas fa-user text-primary me-2"></i>

                    Full Name

                </span>

                <strong>

                    <%= resident.firstName %>

                    <%= resident.lastName %>

                </strong>

            </div>

            <div class="profile-item">

                <span>

                    <i class="fas fa-envelope text-danger me-2"></i>

                    Email

                </span>

                <strong>

                    <%= resident.username %>

                </strong>

            </div>

            <div class="profile-item">

                <span>

                    <i class="fas fa-phone text-success me-2"></i>

                    Phone

                </span>

                <strong>

                    <%= resident.phoneNumber || "Not Added" %>

                </strong>

            </div>

            <div class="profile-item">

                <span>

                    <i class="fas fa-home text-warning me-2"></i>

                    Flat Number

                </span>

                <strong>

                    <%= resident.flatNumber %>

                </strong>

            </div>

            <div class="profile-item">

                <span>

                    <i class="fas fa-user-tag text-info me-2"></i>

                    Role

                </span>

                <strong>

                    <% if(resident.isAdmin){ %>

                        <span class="badge bg-danger">

                            Administrator

                        </span>

                    <% }else{ %>

                        <span class="badge bg-primary">

                            Resident

                        </span>

                    <% } %>

                </strong>

            </div>

            <div class="profile-item border-0">

                <span>

                    <i class="fas fa-check-circle text-success me-2"></i>

                    Status

                </span>

                <strong>

                    <% if(resident.validation==="approved"){ %>

                        <span class="badge bg-success">

                            Approved

                        </span>

                    <% }else if(resident.validation==="applied"){ %>

                        <span class="badge bg-warning text-dark">

                            Pending

                        </span>

                    <% }else{ %>

                        <span class="badge bg-danger">

                            Rejected

                        </span>

                    <% } %>

                </strong>

            </div>

        </div>

    </div>

</div>

<!-- ==========================================================
     SOCIETY INFORMATION
========================================================== -->

<div class="col-lg-6">

    <div class="card shadow-sm border-0 rounded-4 h-100">

        <div class="card-body p-4">

            <div class="d-flex align-items-center mb-4">

                <div class="icon-box bg-success">

                    <i class="fas fa-building text-white"></i>

                </div>

                <div class="ms-3">

                    <h4 class="fw-bold mb-0">

                        Society Information

                    </h4>

                    <small class="text-muted">

                        Apartment details

                    </small>

                </div>

            </div>

            <div class="profile-item">

                <span>

                    <i class="fas fa-city text-success me-2"></i>

                    Society

                </span>

                <strong>

                    <%= society.societyName %>

                </strong>

            </div>

            <div class="profile-item">

                <span>

                    <i class="fas fa-map-marker-alt text-danger me-2"></i>

                    Address

                </span>

                <strong>

                    <%= society.societyAddress.address %>

                </strong>

            </div>

            <div class="profile-item">

                <span>

                    <i class="fas fa-map text-primary me-2"></i>

                    City

                </span>

                <strong>

                    <%= society.societyAddress.city %>

                </strong>

            </div>

            <div class="profile-item">

                <span>

                    <i class="fas fa-location-arrow text-warning me-2"></i>

                    District

                </span>

                <strong>

                    <%= society.societyAddress.district %>

                </strong>

            </div>

            <div class="profile-item">

                <span>

                    <i class="fas fa-mail-bulk text-info me-2"></i>

                    Postal Code

                </span>

                <strong>

                    <%= society.societyAddress.postalCode %>

                </strong>

            </div>

            <div class="profile-item border-0">

                <span>

                    <i class="fas fa-check-circle text-success me-2"></i>

                    Society Status

                </span>

                <strong>

                    <span class="badge bg-success">

                        Active

                    </span>

                </strong>

            </div>

        </div>

    </div>

</div>

</div>

<!-- ==========================================================
     QUICK ACTIONS
========================================================== -->

<div class="row mt-5">

    <div class="col-lg-12">

        <h3 class="fw-bold mb-4">

            <i class="fas fa-bolt text-warning me-2"></i>

            Quick Actions

        </h3>

    </div>

    <!-- Edit Profile -->

    <div class="col-xl-3 col-md-6 mb-4">

        <a href="/editProfile" class="text-decoration-none">

            <div class="action-card">

                <div class="action-icon bg-primary">

                    <i class="fas fa-user-edit"></i>

                </div>

                <h5>Edit Profile</h5>

                <p>

                    Update your personal information.

                </p>

            </div>

        </a>

    </div>

    <!-- Security -->

    <div class="col-xl-3 col-md-6 mb-4">

        <a href="/security" class="text-decoration-none">

            <div class="action-card">

                <div class="action-icon bg-danger">

                    <i class="fas fa-user-shield"></i>

                </div>

                <h5>Security</h5>

                <p>

                    Password, 2FA and login settings.

                </p>

            </div>

        </a>

    </div>

    <!-- Password -->

    <div class="col-xl-3 col-md-6 mb-4">

        <a href="/changePassword" class="text-decoration-none">

            <div class="action-card">

                <div class="action-icon bg-warning">

                    <i class="fas fa-key"></i>

                </div>

                <h5>Password</h5>

                <p>

                    Change your account password.

                </p>

            </div>

        </a>

    </div>

    <!-- Login History -->

    <div class="col-xl-3 col-md-6 mb-4">

        <a href="/loginHistory" class="text-decoration-none">

            <div class="action-card">

                <div class="action-icon bg-success">

                    <i class="fas fa-history"></i>

                </div>

                <h5>Login History</h5>

                <p>

                    View your recent sign-in activity.

                </p>

            </div>

        </a>

    </div>

</div>

<!-- ==========================================================
     ACCOUNT SUMMARY
========================================================== -->

<div class="row mt-5">

    <div class="col-lg-3 col-md-6 mb-4">

        <div class="summary-card">

            <i class="fas fa-file-alt text-primary fa-2x mb-3"></i>

            <h2>

                <%= resident.complaints ? resident.complaints.length : 0 %>

            </h2>

            <p>

                Complaints

            </p>

        </div>

    </div>

    <div class="col-lg-3 col-md-6 mb-4">

        <div class="summary-card">

            <i class="fas fa-wallet text-success fa-2x mb-3"></i>

            <h2>

                ₹<%= resident.makePayment || 0 %>

            </h2>

            <p>

                Maintenance

            </p>

        </div>

    </div>

    <div class="col-lg-3 col-md-6 mb-4">

        <div class="summary-card">

            <i class="fas fa-history text-warning fa-2x mb-3"></i>

            <h2>

                <%= resident.loginHistory ? resident.loginHistory.length : 0 %>

            </h2>

            <p>

                Login History

            </p>

        </div>

    </div>

    <div class="col-lg-3 col-md-6 mb-4">

        <div class="summary-card">

            <i class="fas fa-receipt text-danger fa-2x mb-3"></i>

            <h2>

                <%= resident.paymentHistory ? resident.paymentHistory.length : 0 %>

            </h2>

            <p>

                Payments

            </p>

        </div>

    </div>

</div>