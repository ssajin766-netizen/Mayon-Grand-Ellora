<!-- ==========================================================
     PROFILE PAGE
========================================================== -->

<%- include("partials/header") %>

<div class="container py-5">

    <div class="row align-items-center">

 <!-- ===============================
     PROFILE PHOTO
================================ -->

<div class="col-lg-3 text-center">

    <form
        action="/profile/upload"
        method="POST"
        enctype="multipart/form-data"
        id="profileUploadForm">

        <input
            type="file"
            name="profileImage"
            id="profileImage"
            accept="image/*"
            hidden>

        <div class="profile-photo-wrapper">

            <!-- Profile Image -->

            <img
               id="profilePreview"
               src="<%= resident.profileImage || '/images/default-avatar.png' %>"
               class="profile-photo"
               alt="Profile"
               loading="lazy"
               data-bs-toggle="modal"
               data-bs-target="#profileImageModal"
               onerror="this.onerror=null;this.src='/images/default-avatar.png';">

            <!-- Online Indicator -->

            <% if(resident.validation === "approved"){ %>

                <span class="online-status"></span>

            <% } %>

            <!-- Camera Button -->

            <button
                 type="button"
                 class="camera-btn"
                 onclick="document.getElementById('profileImage').click()">

                   <i class="fas fa-camera"></i>

            </button>

            <!-- Verification Badge -->

            <% if(resident.isEmailVerified){ %>

                <span class="verified-badge">

                    <i class="fas fa-check"></i>

                </span>

            <% } %>

        </div>

    </form>

</div>

    </div>


                <!-- ===============================
                     USER INFORMATION
                ================================ -->

                <div class="col-lg-6 mt-4 mt-lg-0">

                    <h2 class="fw-bold mb-2">

                        <%= resident.firstName %>

                        <%= resident.lastName %>

                    </h2>

                    <p class="text-muted mb-2">

                        <i class="fas fa-envelope text-primary me-2"></i>

                        <%= resident.username %>

                    </p>

                    <p class="text-muted mb-2">

                        <i class="fas fa-phone text-success me-2"></i>

                        <%= resident.phoneNumber || "Not Added" %>

                    </p>

                    <p class="text-muted mb-3">

                        <i class="fas fa-home text-warning me-2"></i>

                        Flat <%= resident.flatNumber %>

                    </p>

                    <!-- Status Badges -->

           <div class="d-flex flex-wrap gap-2">

                        <% if(resident.isEmailVerified){ %>

                            <span class="badge bg-success">

                                <i class="fas fa-check-circle me-1"></i>

                                Email Verified

                            </span>

                        <% } %>

                        <% if(resident.isPhoneVerified){ %>

                            <span class="badge bg-primary">

                                <i class="fas fa-mobile-alt me-1"></i>

                                Phone Verified

                            </span>

                        <% } %>

                        <% if(resident.validation==="approved"){ %>

                            <span class="badge bg-success">

                                Approved

                            </span>

                        <% }else{ %>

                            <span class="badge bg-warning text-dark">

                                Pending

                            </span>

                        <% } %>

                        <% if(resident.isAdmin){ %>

                            <span class="badge bg-danger">

                                Administrator

                            </span>

                        <% }else{ %>

                            <span class="badge bg-info text-dark">

                                Resident

                            </span>

                        <% } %>

                    </div>

                </div>
                <!-- ===============================
                     ACTION BUTTONS
                ================================ -->

                <div class="col-lg-3 mt-4 mt-lg-0">

                    <div class="d-grid gap-3">

                        <a
                            href="/editProfile"
                            class="btn btn-primary">

                            <i class="fas fa-user-edit me-2"></i>

                            Edit Profile

                        </a>

                        <a
                            href="/security"
                            class="btn btn-outline-danger">

                            <i class="fas fa-user-shield me-2"></i>

                            Security

                        </a>

                        <a
                            href="/changePassword"
                            class="btn btn-outline-dark">

                            <i class="fas fa-key me-2"></i>

                            Change Password

                        </a>

                        <a
                           href="/delete-account"
                           class="btn btn-danger w-100">

                            <i class="fas fa-user-times me-2"></i>
                               Delete Account

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="row g-4">

         <!-- ==================================================
             PERSONAL INFORMATION
        =================================================== -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0 rounded-4 h-100">

                <div class="card-header bg-primary text-white py-3">

                    <h4 class="mb-0">

                        <i class="fas fa-user-circle me-2"></i>

                        Personal Information

                    </h4>

                </div>

                <div class="card-body">

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-user text-primary me-2"></i>

                            Full Name

                        </span>

                        <strong>

                            <%= resident.firstName %>

                            <%= resident.lastName %>

                        </strong>

                    </div>

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-envelope text-danger me-2"></i>

                            Email

                        </span>

                        <strong>

                            <%= resident.username %>

                        </strong>

                    </div>

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-phone text-success me-2"></i>

                            Phone Number

                        </span>

                        <strong>

                            <%= resident.phoneNumber || "Not Added" %>

                        </strong>

                    </div>

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-home text-warning me-2"></i>

                            Flat Number

                        </span>

                        <strong>

                            <%= resident.flatNumber %>

                        </strong>

                    </div>

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-id-card text-info me-2"></i>

                            Resident ID

                        </span>

                        <strong>

                            <%= resident._id %>

                        </strong>

                    </div>

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-calendar text-secondary me-2"></i>

                            Member Since

                        </span>

                        <strong>

                            <%= new Date(resident.createdAt).toLocaleDateString() %>

                        </strong>

                    </div>

                </div>

            </div>

        </div>

        <!-- ==================================================
             SOCIETY INFORMATION
        =================================================== -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0 rounded-4 h-100">

                <div class="card-header bg-success text-white py-3">

                    <h4 class="mb-0">

                        <i class="fas fa-building me-2"></i>

                        Society Information

                    </h4>

                </div>

                <div class="card-body">

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-city text-primary me-2"></i>

                            Society Name

                        </span>

                        <strong>

                            <%= resident.societyName %>

                        </strong>

                    </div>

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-check-circle text-success me-2"></i>

                            Approval Status

                        </span>

                        <strong>

                            <% if(resident.validation==="approved"){ %>

                                <span class="badge bg-success text-dark">

                                    Approved

                                </span>

                            <% }else{ %>

                                <span class="badge bg-warning text-dark">

                                    Pending

                                </span>

                            <% } %>

                        </strong>

                    </div>

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-user-shield text-danger me-2"></i>

                            Role

                        </span>

                        <strong>

                            <% if(resident.isAdmin){ %>

                                Administrator

                            <% }else{ %>

                                Resident

                            <% } %>

                        </strong>

                    </div>

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-envelope-open-text text-info me-2"></i>

                            Email Status

                        </span>

                        <strong>

                            <% if(resident.isEmailVerified){ %>

                                <span class="badge bg-success text-dark">

                                    Verified

                                </span>

                            <% }else{ %>

                                <span class="badge bg-danger text-dark">

                                    Not Verified

                                </span>

                            <% } %>

                        </strong>

                    </div>

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-mobile-alt text-success me-2"></i>

                            Phone Status

                        </span>

                        <strong>

                            <% if(resident.isPhoneVerified){ %>

                                <span class="badge bg-success text-dark">

                                    Verified

                                </span>

                            <% }else{ %>

                                <span class="badge bg-danger text-dark">

                                    Not Verified

                                </span>

                            <% } %>

                        </strong>

                    </div>

                    <div class="profile-item">

                        <span>

                            <i class="fas fa-clock text-secondary me-2"></i>

                            Last Login

                        </span>

                        <strong>

                            <%= resident.lastLogin
                                ? new Date(resident.lastLogin).toLocaleString()
                                : "N/A" %>

                        </strong>

                    </div>

                </div>

            </div>

        </div>

    </div>

    
        
<!-- ======================================================
         DASHBOARD SUMMARY
======================================================= -->

    <div class="row g-4 mt-5">
      
        

        <!-- Bills -->

        <div class="col-lg-3 col-md-6">

            <div class="summary-card">

                <div
                    class="action-icon bg-success">

                    <i class="fas fa-file-invoice-dollar"></i>

                </div>

                <h2>

                    ₹ <%= resident.makePayment || 0 %>

                </h2>

                <p>

                    Pending Maintenance

                </p>

            </div>

        </div>

        <!-- Complaints -->

        <div class="col-lg-3 col-md-6">

            <div class="summary-card">

                <div
                    class="action-icon bg-danger">

                    <i class="fas fa-tools"></i>

                </div>

                <h2>

                    <%= resident.complaints
                        ? resident.complaints.length
                        : 0 %>

                </h2>

                <p>

                    Complaints

                </p>

            </div>

        </div>

        <!-- Notices -->

        <div class="col-lg-3 col-md-6">

            <div class="summary-card">

                <div
                    class="action-icon bg-warning">

                    <i class="fas fa-bullhorn"></i>

                </div>

                <h2>

                    <%= typeof noticeCount !== "undefined"
                        ? noticeCount
                        : 0 %>

                </h2>

                <p>

                    Notices

                </p>

            </div>

        </div>

        <!-- Visitors -->

        <div class="col-lg-3 col-md-6">

            <div class="summary-card">

                <div
                    class="action-icon bg-primary">

                    <i class="fas fa-users"></i>

                </div>

                <h2>

                    <% if(resident.isAdmin){ %>

                        <%= typeof visitorCount !== "undefined"
                            ? visitorCount
                            : 0 %>

                    <% }else{ %>

                        <%= resident.visitors
                            ? resident.visitors.length
                            : 0 %>

                    <% } %>

                </h2>

                <p>

                    Visitors

                </p>

            </div>

        </div>

    </div>

     
        
    <!-- ======================================================
         QUICK ACTIONS
    ======================================================= -->
    <div class="row g-4 mt-5">

    

        <!-- Bills -->

        <div class="col-lg-4 col-md-6">

            <div class="action-card">

                <div class="action-icon bg-success">

                    <i class="fas fa-file-invoice-dollar"></i>

                </div>

                <h4>

                    Maintenance Bills

                </h4>

                <p class="text-muted">

                    View and pay your monthly maintenance bill.

                </p>

                <a
                    href="/bill"
                    class="btn btn-success">

                    Open Bills

                </a>

            </div>

        </div>

        <!-- Complaints -->

        <div class="col-lg-4 col-md-6">

            <div class="action-card">

                <div class="action-icon bg-danger">

                    <i class="fas fa-tools"></i>

                </div>

                <h4>

                    Complaints

                </h4>

                <p class="text-muted">

                    Submit and monitor maintenance complaints.

                </p>

                <a
                    href="/complaint"
                    class="btn btn-danger">

                    Open Complaints

                </a>

            </div>

        </div>

        <!-- Noticeboard -->

        <div class="col-lg-4 col-md-6">

            <div class="action-card">

                <div class="action-icon bg-warning">

                    <i class="fas fa-bullhorn"></i>

                </div>

                <h4>

                    Noticeboard

                </h4>

                <p class="text-muted">

                    Read the latest announcements from your society.

                </p>

                <a
                    href="/noticeboard"
                    class="btn btn-warning text-dark">

                    View Notices

                </a>

            </div>

        </div>

        <!-- Login History -->

        <div class="col-lg-4 col-md-6">

            <div class="action-card">

                <div class="action-icon bg-primary">

                    <i class="fas fa-history"></i>

                </div>

                <h4>

                    Login History

                </h4>

                <p class="text-muted">

                    Review recent login activity.

                </p>

                <a
                    href="/loginHistory"
                    class="btn btn-primary">

                    View History

                </a>

            </div>

        </div>

        <!-- Security -->

        <div class="col-lg-4 col-md-6">

            <div class="action-card">

                <div class="action-icon bg-dark">

                    <i class="fas fa-user-shield"></i>

                </div>

                <h4>

                    Security

                </h4>

                <p class="text-muted">

                    Manage password, OTP and account security.

                </p>

                <a
                    href="/security"
                    class="btn btn-dark">

                    Open Security

                </a>

            </div>

        </div>

        <!-- Residents -->

        <% if(resident.isAdmin){ %>

        <div class="col-lg-4 col-md-6">

            <div class="action-card">

                <div class="action-icon bg-info">

                    <i class="fas fa-users"></i>

                </div>

                <h4>

                    Residents

                </h4>

                <p class="text-muted">

                    Manage society members and approvals.

                </p>

                <a
                    href="/residents"
                    class="btn btn-info text-white">

                    Manage Residents

                </a>

            </div>

        </div>

        <% } %>

    </div>

    <!-- ======================================================
         RECENT PAYMENT
    ======================================================= -->

    <% if(resident.lastPayment && resident.lastPayment.amount){ %>

    <div class="card shadow-sm border-0 rounded-4 mt-5">

        <div class="card-header bg-success text-white">

            <h4 class="mb-0">

                <i class="fas fa-receipt me-2"></i>

                Latest Payment

            </h4>

        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-4">

                    <strong>Invoice</strong>

                    <p>

                        <%= resident.lastPayment.invoice || "-" %>

                    </p>

                </div>

                <div class="col-md-4">

                    <strong>Amount</strong>

                    <p>

                        ₹ <%= resident.lastPayment.amount %>

                    </p>

                </div>

                <div class="col-md-4">

                    <strong>Paid On</strong>

                    <p>

                        <%= resident.lastPayment.date
                            ? new Date(resident.lastPayment.date).toLocaleDateString()
                            : "-" %>

                    </p>

                </div>

            </div>

        </div>

    </div>

    <% } %>

</div>
<!-- ==========================================================
     PROFILE IMAGE PREVIEW
========================================================== -->

<script>
document.addEventListener("DOMContentLoaded", () => {

    const imageInput = document.getElementById("profileImage");
    const profilePreview = document.getElementById("profilePreview");
    const modalProfileImage = document.getElementById("modalProfileImage");
    const uploadForm = document.getElementById("profileUploadForm");

    if (!imageInput || !uploadForm) return;

    imageInput.addEventListener("change", function () {

        const file = this.files[0];

        if (!file) return;

        if (!file.type.startsWith("image/")) {
            alert("Please select a valid image.");
            this.value = "";
            return;
        }

        if (file.size > 5 * 1024 * 1024) {
            alert("Image size must be less than 5 MB.");
            this.value = "";
            return;
        }

        const reader = new FileReader();

        reader.onload = function (e) {

            if (profilePreview)
                profilePreview.src = e.target.result;

            if (modalProfileImage)
                modalProfileImage.src = e.target.result;

        };

        reader.readAsDataURL(file);

        uploadForm.submit();

    });

});
</script>

<script> 
document.addEventListener("DOMContentLoaded", () => {

    /* ======================================================
       DELETE ACCOUNT
    ====================================================== */

    const deleteInput = document.getElementById("deleteConfirm");
    const deleteBtn = document.getElementById("deleteBtn");
    const deleteForm = document.querySelector('form[action="/delete-account"]');

    if (deleteInput && deleteBtn && deleteForm) {

        deleteInput.addEventListener("input", () => {

            const confirmed = deleteInput.value.trim() === "DELETE";

            deleteBtn.disabled = !confirmed;

        });

        deleteForm.addEventListener("submit", function (e) {

            if (deleteInput.value.trim() !== "DELETE") {

                e.preventDefault();
                return;

            }

            deleteBtn.disabled = true;

            deleteBtn.innerHTML = `
                <span class="spinner-border spinner-border-sm me-2"></span>
                Deleting...
            `;

        });

    }

    /* ======================================================
       DELETE SOCIETY
    ====================================================== */

    const societyInput = document.getElementById("deleteSocietyConfirm");
    const societyBtn = document.getElementById("deleteSocietyBtn");
    const societyForm = document.getElementById("deleteSocietyForm");

    if (societyInput && societyBtn && societyForm) {

        societyInput.addEventListener("input", () => {

            const confirmed =
                societyInput.value.trim() === "DELETE SOCIETY";

            societyBtn.disabled = !confirmed;

        });

        societyForm.addEventListener("submit", function (e) {

            if (societyInput.value.trim() !== "DELETE SOCIETY") {

                e.preventDefault();
                return;

            }

            societyBtn.disabled = true;

            societyBtn.innerHTML = `
                <span class="spinner-border spinner-border-sm me-2"></span>
                Deleting...
            `;

        });

    }

});
</script>

<!-- ==========================================
     PROFILE IMAGE MODAL
========================================== -->

<div
    class="modal fade"
    id="profileImageModal"
    tabindex="-1"
    aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered modal-xl">

        <div class="modal-content bg-transparent border-0">

            <button
                type="button"
                class="btn-close btn-close-white position-absolute top-0 end-0 m-4"
                data-bs-dismiss="modal">
            </button>

            <div class="text-center">

                <img
                    id="modalProfileImage"
                    src="<%= resident.profileImage || '/images/default-avatar.png' %>"
                    class="profile-modal-image"
                    alt="Profile"
                    onerror="this.onerror=null;this.src='/images/default-avatar.png';">

            </div>

        </div>

    </div>

</div>

<%- include("partials/footer") %>       