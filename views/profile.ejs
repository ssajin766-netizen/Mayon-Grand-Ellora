<%- include('partials/header') %>

<div class="container py-5">

    <div class="row mb-4">

        <div class="col-lg-12">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="card-body bg-primary text-white p-5">

                    <div class="row align-items-center">

                        <div class="col-lg-2 text-center">

                           <img
                               id="profilePreview"
                               src="<%= resident.profileImage || '/images/default-avatar.png' %>"
                               class="rounded-circle border border-4 border-white shadow"
                               width="150"
                               height="150"
                               style="object-fit:cover;"
                               alt="Profile">

                            <form
                               action="/profile/upload"
                               method="POST"
                               enctype="multipart/form-data"
                               class="mt-3">

                            <input
                               type="file"
                               id="profileImage"
                               name="profileImage"
                               class="d-none"
                               accept="image/*"
                               required>

                            <label
                               for="profileImage"
                               class="btn btn-light btn-sm">

                               <i class="fas fa-camera me-2"></i>

                                   Choose Photo

                            </label>

                            <button
                                type="submit"
                                class="btn btn-success btn-sm mt-2 w-100">

                                <i class="fas fa-upload me-2"></i>

                                       Upload

                            </button>

                    </form>

             </div>

                        <div class="col-lg-6">

                            <h2 class="fw-bold mb-2">

                                <%= resident.firstName %>

                                <%= resident.lastName %>

                            </h2>

                            <p class="mb-2">

                                <i class="fas fa-envelope me-2"></i>

                                <%= resident.username %>

                            </p>

                            <p class="mb-0">

                                <i class="fas fa-home me-2"></i>

                                Flat

                                <%= resident.flatNumber %>

                            </p>

                        </div>

                        <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">

                            <a
                                href="/editProfile"
                                class="btn btn-light me-2">

                                <i class="fas fa-user-edit me-2"></i>

                                Edit Profile

                            </a>

                            <a
                                href="/security"
                                class="btn btn-danger">

                                <i class="fas fa-user-shield me-2"></i>

                                Security

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="row g-4">
    
<!-- ==========================================================
     PERSONAL INFORMATION
========================================================== -->

<div class="col-lg-6">

    <div class="card shadow-lg border-0 rounded-4 h-100">

        <div class="card-header bg-white border-0 pt-4">

            <h4 class="fw-bold text-primary">

                <i class="fas fa-user-circle me-2"></i>

                Personal Information

            </h4>

            <small class="text-muted">

                Your personal account details.

            </small>

        </div>

        <div class="card-body">

            <!-- Name -->

            <div class="d-flex justify-content-between py-3 border-bottom">

                <div>

                    <i class="fas fa-user text-primary me-2"></i>

                    <strong>Full Name</strong>

                </div>

                <span class="text-secondary">

                    <%= resident.firstName %>

                    <%= resident.lastName %>

                </span>

            </div>

            <!-- Email -->

            <div class="d-flex justify-content-between py-3 border-bottom">

                <div>

                    <i class="fas fa-envelope text-danger me-2"></i>

                    <strong>Email</strong>

                </div>

                <span class="text-secondary">

                    <%= resident.username %>

                </span>

            </div>

            <!-- Phone -->

            <div class="d-flex justify-content-between py-3 border-bottom">

                <div>

                    <i class="fas fa-phone text-success me-2"></i>

                    <strong>Phone</strong>

                </div>

                <span class="text-secondary">

                    <%= resident.phoneNumber || "Not Added" %>

                </span>

            </div>

            <!-- Flat -->

            <div class="d-flex justify-content-between py-3 border-bottom">

                <div>

                    <i class="fas fa-home text-warning me-2"></i>

                    <strong>Flat Number</strong>

                </div>

                <span class="text-secondary">

                    <%= resident.flatNumber %>

                </span>

            </div>

            <!-- Account Type -->

            <div class="d-flex justify-content-between py-3 border-bottom">

                <div>

                    <i class="fas fa-user-tag text-info me-2"></i>

                    <strong>Role</strong>

                </div>

                <span>

                    <% if(resident.isAdmin){ %>

                        <span class="badge bg-danger">

                            Administrator

                        </span>

                    <% } else { %>

                        <span class="badge bg-primary">

                            Resident

                        </span>

                    <% } %>

                </span>

            </div>

            <!-- Status -->

            <div class="d-flex justify-content-between py-3">

                <div>

                    <i class="fas fa-check-circle text-success me-2"></i>

                    <strong>Approval Status</strong>

                </div>

                <span>

                    <% if(resident.validation==="approved"){ %>

                        <span class="badge bg-success">

                            Approved

                        </span>

                    <% } else if(resident.validation==="applied"){ %>

                        <span class="badge bg-warning text-dark">

                            Pending

                        </span>

                    <% } else { %>

                        <span class="badge bg-danger">

                            Rejected

                        </span>

                    <% } %>

                </span>

            </div>

        </div>

    </div>

</div>

<!-- ==========================================================
     SOCIETY INFORMATION
========================================================== -->

<div class="col-lg-6">

    <div class="card shadow-lg border-0 rounded-4 h-100">

        <div class="card-header bg-white border-0 pt-4">

            <h4 class="fw-bold text-success">

                <i class="fas fa-building me-2"></i>

                Society Information

            </h4>

            <small class="text-muted">

                Details about your apartment society.

            </small>

        </div>

        <div class="card-body">

            <!-- Society Name -->

            <div class="d-flex justify-content-between py-3 border-bottom">

                <div>

                    <i class="fas fa-city text-success me-2"></i>

                    <strong>Society Name</strong>

                </div>

                <span class="text-secondary">

                    <%= society.societyName %>

                </span>

            </div>

            <!-- Address -->

            <div class="py-3 border-bottom">

                <div class="mb-2">

                    <i class="fas fa-map-marker-alt text-danger me-2"></i>

                    <strong>Address</strong>

                </div>

                <div class="text-secondary ms-4">

                    <%= society.societyAddress.address %>

                </div>

            </div>

            <!-- City -->

            <div class="d-flex justify-content-between py-3 border-bottom">

                <div>

                    <i class="fas fa-map text-primary me-2"></i>

                    <strong>City</strong>

                </div>

                <span class="text-secondary">

                    <%= society.societyAddress.city %>

                </span>

            </div>

            <!-- District -->

            <div class="d-flex justify-content-between py-3 border-bottom">

                <div>

                    <i class="fas fa-location-arrow text-warning me-2"></i>

                    <strong>District</strong>

                </div>

                <span class="text-secondary">

                    <%= society.societyAddress.district %>

                </span>

            </div>

            <!-- Postal Code -->

            <div class="d-flex justify-content-between py-3 border-bottom">

                <div>

                    <i class="fas fa-mail-bulk text-info me-2"></i>

                    <strong>Postal Code</strong>

                </div>

                <span class="text-secondary">

                    <%= society.societyAddress.postalCode %>

                </span>

            </div>

            <!-- Society Status -->

            <div class="d-flex justify-content-between py-3 border-bottom">

                <div>

                    <i class="fas fa-check-circle text-success me-2"></i>

                    <strong>Status</strong>

                </div>

                <span class="badge bg-success">

                    Active

                </span>

            </div>

            <!-- Membership -->

            <div class="d-flex justify-content-between py-3">

                <div>

                    <i class="fas fa-users text-primary me-2"></i>

                    <strong>Membership</strong>

                </div>

                <span class="badge bg-primary">

                    Resident

                </span>

            </div>

        </div>

    </div>

</div>

</div>

<!-- ==========================================================
     QUICK ACTIONS
========================================================== -->

<div class="row mt-5">

    <div class="col-lg-12">

        <div class="card shadow-lg border-0 rounded-4">

            <div class="card-body">

                <h4 class="fw-bold mb-4">

                    <i class="fas fa-bolt text-warning me-2"></i>

                    Quick Actions

                </h4>

                <div class="row text-center">

                    <div class="col-md-3 mb-3">

                        <a
                            href="/editProfile"
                            class="btn btn-primary w-100 py-3">

                            <i class="fas fa-user-edit fa-2x mb-2"></i>

                            <br>

                            Edit Profile

                        </a>

                    </div>

                    <div class="col-md-3 mb-3">

                        <a
                            href="/security"
                            class="btn btn-danger w-100 py-3">

                            <i class="fas fa-user-shield fa-2x mb-2"></i>

                            <br>

                            Security

                        </a>

                    </div>

                    <div class="col-md-3 mb-3">

                        <a
                            href="/changePassword"
                            class="btn btn-warning w-100 py-3">

                            <i class="fas fa-key fa-2x mb-2"></i>

                            <br>

                            Change Password

                        </a>

                    </div>

                    <div class="col-md-3 mb-3">

                        <a
                            href="/loginHistory"
                            class="btn btn-info text-white w-100 py-3">

                            <i class="fas fa-history fa-2x mb-2"></i>

                            <br>

                            Login History

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

document.addEventListener("DOMContentLoaded", function () {

    const profileInput = document.getElementById("profileImage");
    const preview = document.getElementById("profilePreview");

    if (!profileInput || !preview) return;

    profileInput.addEventListener("change", function () {

        if (!this.files.length) return;

        const reader = new FileReader();

        reader.onload = function (e) {

            preview.src = e.target.result;

        };

        reader.readAsDataURL(this.files[0]);

    });

});

</script>

<%- include("partials/footer") %>