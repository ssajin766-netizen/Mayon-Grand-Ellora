<!-- ==========================================================
     LOGIN PAGE
========================================================== -->

<%- include("partials/headerForm") %>

<style>

body{

    background:#f5f7fb;

}

.login-card{

    border:none;

    border-radius:22px;

    box-shadow:0 15px 40px rgba(0,0,0,.08);

}

.logo{

    width:90px;

    height:90px;

    border-radius:50%;

    box-shadow:0 10px 25px rgba(0,0,0,.15);

}

.form-label{

    font-weight:600;

}

.input-group-text{

    background:#fff;

    border-right:none;

    height:58px;

}

.form-control{

    height:58px;

    border-left:none;

    border-radius:0;

}

.form-control:focus{

    box-shadow:none;

    border-color:#ced4da;

}

.password-toggle{

    height:58px;

    width:58px;

    background:#fff;

    border:1px solid #ced4da;

    border-left:none;

    display:flex;

    align-items:center;

    justify-content:center;

}

.password-toggle:hover{

    background:#f8f9fa;

}

.input-group{

    border-radius:12px;

    overflow:hidden;

}

.btn{

    border-radius:12px;

    font-weight:600;

    height:54px;

}

.social-btn{

    height:54px;

    display:flex;

    align-items:center;

    justify-content:center;

    gap:10px;

}

</style>

<body>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-5 col-md-7">

            <div class="card login-card">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <img
                            src="/images/diversity.png"
                            class="logo mb-3">

                        <h2 class="fw-bold">

                            Welcome Back

                        </h2>

                        <p class="text-muted">

                            Sign in to your Mayon Grand Ellora account

                        </p>

                    </div>

                    <% if(error && error.length){ %>

                        <div class="alert alert-danger">

                            <%= error %>

                        </div>

                    <% } %>

                    <% if(success && success.length){ %>

                        <div class="alert alert-success">

                            <%= success %>

                        </div>

                    <% } %>

                    <form action="/login" method="POST">

                        <!-- Email -->

                        <div class="mb-3">

                            <label class="form-label">

                                Email Address

                            </label>

                            <div class="input-group">

                                <span class="input-group-text">

                                    <i class="fas fa-envelope"></i>

                                </span>

                                <input
                                    type="email"
                                    class="form-control"
                                    name="username"
                                    placeholder="Enter your email"
                                    required
                                    autofocus>

                            </div>

                        </div>

                        <!-- Password -->

                        <div class="mb-3">

                            <label class="form-label">

                                Password

                            </label>

                            <div class="input-group">

                                <span class="input-group-text">

                                    <i class="fas fa-lock"></i>

                                </span>

                                <input
                                    type="password"
                                    id="password"
                                    class="form-control"
                                    name="password"
                                    placeholder="Enter your password"
                                    required>

                                <button
                                    type="button"
                                    class="password-toggle"
                                    id="togglePassword">

                                    <i
                                        class="fas fa-eye"
                                        id="eyeIcon"></i>

                                </button>

                            </div>

                        </div>

                        <div class="text-end mb-4">

                            <a
                                href="/forgot-password"
                                class="text-decoration-none">

                                Forgot Password?

                            </a>

                        </div>

                        <button
                            class="btn btn-dark w-100"
                            type="submit">

                            <i class="fas fa-sign-in-alt me-2"></i>

                            Login

                        </button>

                        <small class="text-muted d-block text-center mt-3">

                            If Two-Step Verification is enabled,
                            you'll be asked to verify your OTP after login.

                        </small>

                        <hr>

                        <a
                            href="/auth/google"
                            class="btn btn-light border social-btn w-100">

                            <img
                                src="https://developers.google.com/identity/images/g-logo.png"
                                width="20">

                            Continue with Google

                        </a>

                        <a
                            href="/loginPhone"
                            class="btn btn-success w-100 mt-3">

                            <i class="fas fa-mobile-alt me-2"></i>

                            Login with Phone

                        </a>

                        <hr>

                        <p class="text-center">

                            Don't have an account?

                        </p>

                        <a
                            href="/signup"
                            class="btn btn-danger w-100">

                            <i class="fas fa-user-plus me-2"></i>

                            Create Account

                        </a>

                        <a
                            href="/"
                            class="btn btn-outline-secondary w-100 mt-3">

                            <i class="fas fa-home me-2"></i>

                            Back to Home

                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

const password=document.getElementById("password");

const toggle=document.getElementById("togglePassword");

const eye=document.getElementById("eyeIcon");

toggle.addEventListener("click",function(){

    if(password.type==="password"){

        password.type="text";

        eye.classList.replace("fa-eye","fa-eye-slash");

    }else{

        password.type="password";

        eye.classList.replace("fa-eye-slash","fa-eye");

    }

});

</script>

</body>

</html>