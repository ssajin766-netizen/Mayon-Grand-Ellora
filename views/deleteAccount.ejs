<%- include("partials/header") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-danger text-white py-4">

                    <h2 class="mb-0">
                        <i class="fas fa-user-times me-2"></i>
                        Delete Your Account
                    </h2>

                </div>

                <div class="card-body p-5">

                    <div class="text-center mb-5">

                        <i class="fas fa-exclamation-triangle text-danger display-1"></i>

                        <h3 class="fw-bold mt-4">
                            We're sorry to see you go.
                        </h3>

                        <p class="text-muted fs-5">
                            Before deleting your account, please review what will happen.
                        </p>

                    </div>

                    <div class="alert alert-warning border-warning">

                        <h5 class="fw-bold mb-3">

                            Your account will permanently lose:

                        </h5>

                        <div class="row">

                            <div class="col-md-6">

                                <ul class="list-unstyled">

                                    <li class="mb-3">
                                        <i class="fas fa-user text-danger me-2"></i>
                                        Profile Information
                                    </li>

                                    <li class="mb-3">
                                        <i class="fas fa-money-check text-danger me-2"></i>
                                        Payment History
                                    </li>

                                    <li class="mb-3">
                                        <i class="fas fa-tools text-danger me-2"></i>
                                        Complaints
                                    </li>

                                    <li class="mb-3">
                                        <i class="fas fa-bell text-danger me-2"></i>
                                        Notifications
                                    </li>

                                </ul>

                            </div>

                            <div class="col-md-6">

                                <ul class="list-unstyled">

                                    <li class="mb-3">
                                        <i class="fas fa-history text-danger me-2"></i>
                                        Login History
                                    </li>

                                    <li class="mb-3">
                                        <i class="fas fa-users text-danger me-2"></i>
                                        Visitor Records
                                    </li>

                                    <li class="mb-3">
                                        <i class="fas fa-building text-danger me-2"></i>
                                        Society Membership
                                    </li>

                                    <li class="mb-3">
                                        <i class="fas fa-image text-danger me-2"></i>
                                        Uploaded Profile Photo
                                    </li>

                                </ul>

                            </div>

                        </div>

                    </div>

                    <div class="alert alert-danger mt-4">

                        <h5 class="fw-bold">
                            <i class="fas fa-radiation me-2"></i>
                            Warning
                        </h5>

                        This action is permanent and cannot be undone.

                    </div>

                    <div class="form-check mt-4">

                        <input
                            class="form-check-input"
                            type="checkbox"
                            id="agreeDelete">

                        <label
                            class="form-check-label"
                            for="agreeDelete">

                            I understand that my account and all associated data will be permanently deleted.

                        </label>

                    </div>

                    <div class="d-flex justify-content-between mt-5">

                        <a href="/profile" class="btn btn-outline-secondary btn-lg">

                            <i class="fas fa-arrow-left me-2"></i>

                            Back

                        </a>

                        <button
                            id="continueBtn"
                            class="btn btn-danger btn-lg"
                            disabled>

                            Continue

                            <i class="fas fa-arrow-right ms-2"></i>

                        </button>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

const agree = document.getElementById("agreeDelete");
const continueBtn = document.getElementById("continueBtn");

agree.addEventListener("change", () => {

    continueBtn.disabled = !agree.checked;

});

continueBtn.addEventListener("click", () => {

    window.location.href = "/delete-account/verify";

});

</script>

<%- include("partials/footer") %>