<!-- ==========================================================
     PERSONAL COMPLAINTS
========================================================== -->

<%- include("partials/header") %>

<div class="container py-4">

    <!-- ==========================================
         Page Header
    =========================================== -->

    <div class="text-center mb-5">

        <h2 class="fw-bold">

            <i class="fas fa-headset text-danger me-2"></i>

            Personal Complaints

        </h2>

        <p class="text-muted">

            Track all your complaints and their current status.

        </p>

    </div>

    <!-- ==========================================
         Raise Complaint
    =========================================== -->

    <div class="text-center mb-5">

        <a

            href="/complaint"

            class="btn btn-danger btn-lg rounded-pill shadow-sm px-4">

            <i class="fas fa-plus-circle me-2"></i>

            Raise Complaint

        </a>

    </div>

    <!-- ==========================================
         Complaint List
    =========================================== -->

    <% if(complaints.length){ %>

    <div class="row g-4">

        <% complaints.slice().reverse().forEach((complaint)=>{ %>

        <div class="col-lg-6">

            <div class="card complaint-card border-0 shadow-sm h-100">

                <div class="card-body">

                    <!-- Header -->

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <h5 class="fw-bold mb-1">

                                <i class="fas fa-tools text-danger me-2"></i>

                                <%= complaint.category %>

                            </h5>

                            <small class="text-muted">

                                <i class="far fa-calendar-alt me-1"></i>

                                <%= complaint.date %>

                            </small>

                        </div>

                        <% if(complaint.status==="open"){ %>

                            <span class="badge bg-success">

                                Open

                            </span>

                        <% }else{ %>

                            <span class="badge bg-danger">

                                Closed

                            </span>

                        <% } %>

                    </div>

                    <hr>

                    <!-- Complaint Type -->

                    <div class="mb-3">

                        <strong>

                            Type

                        </strong>

                        <p class="text-muted mb-0">

                            <%= complaint.type %>

                        </p>

                    </div>

                    <!-- Description -->

                    <div>

                        <strong>

                            Description

                        </strong>

                        <p class="complaint-text">

                            <%= complaint.description %>

                        </p>

                    </div>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

    <% } else { %>

    <!-- ==========================================
         Empty State
    =========================================== -->

    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body text-center py-5">

            <i

                class="fas fa-inbox fa-4x text-secondary mb-4">

            </i>

            <h4>

                No Complaints Found

            </h4>

            <p class="text-muted">

                You haven't raised any complaints yet.

            </p>

            <a

                href="/complaint"

                class="btn btn-danger rounded-pill px-4">

                <i class="fas fa-plus-circle me-2"></i>

                Raise Your First Complaint

            </a>

        </div>

    </div>

    <% } %>

</div>

<style>

/* ==========================================
   Complaint Cards
========================================== */

.complaint-card{

    border-radius:20px;

    transition:.35s;

    overflow:hidden;

}

.complaint-card:hover{

    transform:translateY(-8px);

    box-shadow:0 18px 40px rgba(0,0,0,.15)!important;

}

.complaint-card .card-body{

    padding:28px;

}

.complaint-text{

    color:#495057;

    line-height:1.8;

    white-space:pre-wrap;

}

.badge{

    padding:8px 14px;

    font-size:13px;

}

.card hr{

    margin:18px 0;

}

@media(max-width:768px){

    .complaint-card .card-body{

        padding:22px;

    }

}

</style>

<%- include("partials/footer") %>