<!-- ==========================================================
     LANDING PAGE
========================================================== -->

<!DOCTYPE html>
<html lang="en">

<style>

.hero-section{

    background:
    linear-gradient(rgba(0,0,0,.55), rgba(0,0,0,.45)),
    url("/images/night.png");

    background-size:cover;
    background-position:center;
    background-repeat:no-repeat;

    min-height:90vh;

    display:flex;

    align-items:center;

    color:#fff;

}

.hero-title{

    font-size:4rem;

    font-weight:700;

}

.hero-subtitle{

    font-size:1.2rem;

    max-width:650px;

}

</style>

<head>

    <title>Mayon Grand Ellora</title>

    <meta charset="utf-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1">

    <meta
        name="description"
        content="Modern Housing Society Management System">

    <meta
        name="google-site-verification"
        content="P8hqAw19_O3IT82LJYjlEsI9TDS9vMATQkZXKoe2M8E">

    <link
        rel="shortcut icon"
        href="/images/favicon.ico">

    <!-- Bootstrap 5 -->

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <!-- Font Awesome -->

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <!-- AOS -->

    <link
        rel="stylesheet"
        href="https://unpkg.com/aos@next/dist/aos.css"/>

    <link
        rel="stylesheet"
        href="/styles.css">

    <% if(process.env.NODE_ENV==="production"){ %>

        <%- include("scripts/adsense") %>

        <%- include("scripts/tagManager") %>

    <% } %>

</head>

<body>

<!-- ==========================================================
     NAVBAR
========================================================== -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">

    <div class="container">

        <!-- Brand -->

        <a
            href="/"
            class="navbar-brand fw-bold fs-4">

            Mayon Grand Ellora

        </a>

        <!-- Mobile Toggle -->

        <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbar"
            aria-controls="navbar"
            aria-expanded="false"
            aria-label="Toggle navigation">

            <span class="navbar-toggler-icon"></span>

        </button>

        <!-- Menu -->

        <div
            class="collapse navbar-collapse"
            id="navbar">

            <ul class="navbar-nav ms-auto align-items-lg-center">

                <li class="nav-item">

                    <a
                        class="nav-link px-lg-3"
                        href="#features">

                        <i class="fas fa-layer-group me-2"></i>

                        Features

                    </a>

                </li>

                <li class="nav-item">

                    <a
                        class="nav-link px-lg-3"
                        href="#contact">

                        <i class="fas fa-envelope me-2"></i>

                        Contact

                    </a>

                </li>

                <li class="nav-item ms-lg-3 mt-3 mt-lg-0">

                    <a
                        href="/login"
                        class="btn btn-success">

                        <i class="fas fa-sign-in-alt me-2"></i>

                        Login

                    </a>

                </li>

            </ul>

        </div>

    </div>

</nav>

<!-- ==========================================================
     HERO
========================================================== -->

<section class="hero-section">

    <div class="container">

        <div class="row align-items-center">

            <div
                class="col-lg-8 col-xl-7"
                data-aos="fade-right">

                <h1 class="display-2 fw-bold text-white">

                  Smart Society

                <span class="text-white">

                    Management

                </span>

                </h1>

                <p class="lead mt-4">

                    Simplify apartment management with online billing,
                    complaints, notices, resident directory,
                    emergency contacts and secure communication.

                </p>

                <div class="mt-4">

                    <a href="/login" class="btn btn-success btn-lg me-3">
                        Login
                    </a>

                    <a href="/signup" class="btn btn-primary btn-lg me-3">
                        Sign Up
                    </a>

                    <a href="/register" class="btn register-btn btn-lg">
                       Register 
                    </a>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ==========================================================
     FEATURES
========================================================== -->

<section
    id="features"
    class="py-5 bg-light">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="fw-bold">

                Powerful Features

            </h2>

            <p class="text-muted">

                Everything your apartment community needs.

            </p>

        </div>

        <div class="row g-4">

               <!-- Residents -->

        <div class="col-lg-4 col-md-6" data-aos="zoom-in">

            <div class="card h-100 border-0 shadow feature-card">

                <div class="card-body text-center p-4">

                    <div class="feature-icon bg-primary">

                        <i class="fas fa-users"></i>

                    </div>

                    <h4 class="mt-4">

                        Residents

                    </h4>

                    <p class="text-muted">

                        Maintain a complete resident directory with secure approval by the society administrator.

                    </p>

                </div>

            </div>

        </div>

        <!-- Noticeboard -->

        <div class="col-lg-4 col-md-6" data-aos="zoom-in">

            <div class="card h-100 border-0 shadow feature-card">

                <div class="card-body text-center p-4">

                    <div class="feature-icon bg-warning">

                        <i class="fas fa-bullhorn"></i>

                    </div>

                    <h4 class="mt-4">

                        Noticeboard

                    </h4>

                    <p class="text-muted">

                        Publish announcements, events and important updates for every resident.

                    </p>

                </div>

            </div>

        </div>

        <!-- Bills -->

        <div class="col-lg-4 col-md-6" data-aos="zoom-in">

            <div class="card h-100 border-0 shadow feature-card">

                <div class="card-body text-center p-4">

                    <div class="feature-icon bg-success">

                        <i class="fas fa-file-invoice-dollar"></i>

                    </div>

                    <h4 class="mt-4">

                        Online Billing

                    </h4>

                    <p class="text-muted">

                        Generate maintenance bills, download invoices and make secure online payments.

                    </p>

                </div>

            </div>

        </div>

        <!-- Helpdesk -->

        <div class="col-lg-4 col-md-6" data-aos="zoom-in">

            <div class="card h-100 border-0 shadow feature-card">

                <div class="card-body text-center p-4">

                    <div class="feature-icon bg-danger">

                        <i class="fas fa-headset"></i>

                    </div>

                    <h4 class="mt-4">

                        Helpdesk

                    </h4>

                    <p class="text-muted">

                        Raise complaints and track maintenance requests until resolution.

                    </p>

                </div>

            </div>

        </div>

        <!-- Emergency -->

        <div class="col-lg-4 col-md-6" data-aos="zoom-in">

            <div class="card h-100 border-0 shadow feature-card">

                <div class="card-body text-center p-4">

                    <div class="feature-icon bg-info">

                        <i class="fas fa-phone-alt"></i>

                    </div>

                    <h4 class="mt-4">

                        Emergency Contacts

                    </h4>

                    <p class="text-muted">

                        One-click access to hospital, police, fire station, electrician and more.

                    </p>

                </div>

            </div>

        </div>

        <!-- Profile -->

        <div class="col-lg-4 col-md-6" data-aos="zoom-in">

            <div class="card h-100 border-0 shadow feature-card">

                <div class="card-body text-center p-4">

                    <div class="feature-icon bg-secondary">

                        <i class="fas fa-user-circle"></i>

                    </div>

                    <h4 class="mt-4">

                        Profile Management

                    </h4>

                    <p class="text-muted">

                        Keep your personal information and apartment details always updated.

                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ==========================================================
     CONTACT
========================================================== -->

<section id="contact" class="py-5">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-lg-7 col-xl-6">

                <div class="card border-0 shadow-lg rounded-4">

                    <div class="card-body p-5">

                        <h2 class="text-center fw-bold mb-3">

                            Contact Us

                        </h2>

                        <p class="text-center text-muted mb-5">

                            We'd love to hear from you.

                        </p>

                        <form>

                            <div class="mb-4">

                                <label class="form-label">

                                    Name

                                </label>

                                <input
                                    type="text"
                                    class="form-control form-control-lg">

                            </div>

                            <div class="mb-4">

                                <label class="form-label">

                                    Email

                                </label>

                                <input
                                    type="email"
                                    class="form-control form-control-lg">

                            </div>

                            <div class="mb-4">

                                <label class="form-label">

                                    Message

                                </label>

                                <textarea
                                    rows="6"
                                    class="form-control"></textarea>

                            </div>

                            <button
                                class="btn btn-success btn-lg w-100">

                                <i class="fas fa-paper-plane me-2"></i>

                                Send Message

                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ==========================================================
     FOOTER
========================================================== -->

<footer class="bg-dark text-white py-5">

    <div class="container">

        <div class="row">

            <div class="col-lg-6">

    <h4 class="fw-bold mb-3">

        Mayon Grand Ellora

    </h4>

    <p class="text-light mb-2">

        <i class="fas fa-map-marker-alt me-2 text-danger"></i>

        SF No. 223/1B48,<br>

        Kalapatti Main Road,<br>

        Behind Dr. NGP College,<br>

        Vellanaipatti,<br>

        Coimbatore - 641048,<br>

        Tamil Nadu, India

    </p>

    <p class="text-light mb-0">

        <i class="fas fa-envelope me-2 text-warning"></i>

        <a
            href="mailto:mayongrandellora@gmail.com"
            class="text-white text-decoration-none">

            mayongrandellora@gmail.com

        </a>

    </p>

</div>
            <div class="col-lg-6 text-lg-end">

                <a
                    href="/login"
                    class="btn btn-success me-2">

                    Login

                </a>

                <a
                    href="/signup"
                    class="btn btn-primary">

                    Register

                </a>

            </div>

        </div>

        <hr class="border-secondary">

        <div class="row">

            <div class="col-md-6">

                © <%= new Date().getFullYear() %>

                Mayon Grand Ellora.

                All Rights Reserved.

            </div>

            <div class="col-md-6 text-md-end">

                <a
                    href="https://github.com/ssajin766-netizen/Mayon-Grand-Ellora"
                    target="_blank"
                    class="text-white fs-4">

                    <i class="fab fa-github"></i>

                </a>

            </div>

        </div>

    </div>

</footer>

<!-- ==========================================================
     CUSTOM CSS
========================================================== -->

<style>

.hero-section h1{

    font-size:3.2rem;

}

.feature-card{

    transition:.35s;

    border-radius:20px;

}

.feature-card:hover{

    transform:translateY(-10px);

    box-shadow:0 20px 40px rgba(0,0,0,.15)!important;

}

.feature-icon{

    width:80px;

    height:80px;

    margin:auto;

    border-radius:50%;

    display:flex;

    justify-content:center;

    align-items:center;

    color:#fff;

    font-size:34px;

}

.stat-card{

    border-radius:20px;

    transition:.3s;

}

.stat-card:hover{

    transform:translateY(-8px);

}

.form-control{

    border-radius:12px;

    padding:12px;

}

.btn{

    border-radius:12px;

    font-weight:600;

}

footer a{

    text-decoration:none;

}

@media(max-width:768px){

    .hero-section{

        padding:80px 0;

        text-align:center;

    }

    .hero-section h1{

        font-size:2.4rem;

    }

}

.register-btn{

    color:#fff;

    border:2px solid rgba(255,255,255,.8);

    background:rgba(255,255,255,.08);

    backdrop-filter:blur(8px);

    border-radius:12px;

    padding:12px 28px;

    font-weight:600;

    transition:.3s;

}

.register-btn:hover{

    background:#fff;

    color:#222;

}

</style>

<!-- ==========================================================
     JAVASCRIPT
========================================================== -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://unpkg.com/aos@next/dist/aos.js"></script>

<script>

AOS.init({

    duration:900,

    once:true

});

</script>

</body>

</html>