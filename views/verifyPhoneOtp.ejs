<%- include("partials/header") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-5 col-md-7">

            <div class="card otp-card shadow-lg border-0">

                <!-- Header -->

                <div class="card-header text-center">

                    <div class="otp-icon">

                        <i class="fas fa-mobile-alt"></i>

                    </div>

                    <h2 class="mt-3 mb-2">

                        Verify OTP

                    </h2>

                    <p>

                        Enter the 6-digit verification code sent to your mobile number.

                    </p>

                </div>

                <!-- Body -->

                <div class="card-body">

                    <% if(success && success.length){ %>

                        <div class="alert alert-success">

                            <%= success %>

                        </div>

                    <% } %>

                    <% if(error && error.length){ %>

                        <div class="alert alert-danger">

                            <%= error %>

                        </div>

                    <% } %>

                    <form action="/phone/verify" method="POST">

                        <div class="form-group mb-4">

                            <label class="font-weight-bold">

                                One Time Password

                            </label>

                            <input

                                type="text"

                                name="otp"

                                class="form-control otp-input"

                                maxlength="6"

                                minlength="6"

                                pattern="[0-9]{6}"

                                placeholder="● ● ● ● ● ●"

                                autocomplete="one-time-code"

                                autofocus

                                required>

                            <small class="text-muted">

                                Example: 123456

                            </small>

                        </div>

                        <button

                            type="submit"

                            class="btn btn-success btn-lg btn-block">

                            <i class="fas fa-check-circle mr-2"></i>

                            Verify OTP

                        </button>

                    </form>

                    <div class="text-center mt-4">

                        <a

                            href="/loginPhone"

                            class="btn btn-outline-secondary btn-block">

                            <i class="fas fa-arrow-left mr-2"></i>

                            Change Mobile Number

                        </a>

                    </div>

                    <!-- Optional -->

                    <div class="text-center mt-3">

                        <small class="text-muted">

                            Didn't receive the OTP?

                        </small>

                        <br>

                        <a href="/loginPhone">

                            Resend OTP

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

body{

    background:#f4f7fb;

}

/* Card */

.otp-card{

    border-radius:20px;

    overflow:hidden;

}

/* Header */

.card-header{

    background:linear-gradient(135deg,#0d6efd,#4e8ef7);

    color:#fff;

    padding:35px;

    border:none;

}

.card-header p{

    opacity:.9;

    margin-bottom:0;

}

/* Icon */

.otp-icon{

    width:85px;

    height:85px;

    margin:auto;

    border-radius:50%;

    background:rgba(255,255,255,.18);

    display:flex;

    align-items:center;

    justify-content:center;

}

.otp-icon i{

    font-size:36px;

}

/* Body */

.card-body{

    padding:40px;

}

/* OTP Input */

.otp-input{

    height:65px;

    font-size:32px;

    letter-spacing:15px;

    text-align:center;

    font-weight:bold;

    border-radius:15px;

}

.otp-input:focus{

    border-color:#198754;

    box-shadow:0 0 0 .2rem rgba(25,135,84,.15);

}

/* Buttons */

.btn{

    height:50px;

    border-radius:12px;

    font-weight:600;

}

.btn-success{

    background:#198754;

    border:none;

}

.btn-success:hover{

    background:#157347;

}

.btn-outline-secondary:hover{

    color:#fff;

}

@media(max-width:576px){

    .card-body{

        padding:25px;

    }

    .otp-input{

        font-size:24px;

        letter-spacing:10px;

    }

}

</style>

<%- include("partials/footer") %>