<%- include('partials/header') %>

<div class="container py-5">

    <!-- Flash Messages -->

    <% if(success && success.length){ %>

        <div class="alert alert-success alert-dismissible fade show">

            <i class="fas fa-check-circle me-2"></i>

            <%= success[0] %>

            <button
                type="button"
                class="btn-close"
                data-bs-dismiss="alert">
            </button>

        </div>

    <% } %>

    <% if(error && error.length){ %>

        <div class="alert alert-danger alert-dismissible fade show">

            <i class="fas fa-times-circle me-2"></i>

            <%= error[0] %>

            <button
                type="button"
                class="btn-close"
                data-bs-dismiss="alert">
            </button>

        </div>

    <% } %>

    <!-- Page Header -->

    <div class="card shadow-lg border-0 rounded-4 mb-4">

        <div class="card-body bg-primary text-white rounded-4">

            <div class="row align-items-center">

                <div class="col-md-2 text-center">

                    <img
                        src="/images/profile.png"
                        class="rounded-circle border border-4 border-white"
                        width="100"
                        height="100">

                </div>

                <div class="col-md-10">

                    <h2 class="fw-bold mb-1">

                        <i class="fas fa-user-shield me-2"></i>

                        Security Center

                    </h2>

                    <p class="mb-0">

                        Manage your account security,
                        verification,
                        password,
                        and login activity.

                    </p>

                </div>

            </div>

        </div>

    </div>

    <!-- Dashboard Cards -->

    <div class="row g-4">

        <!-- Email -->

        <div class="col-lg-6">

            <div class="card shadow-sm h-100">

                <div class="card-header bg-light">

                    <h5 class="mb-0">

                        <i class="fas fa-envelope text-primary me-2"></i>

                        Email Address

                    </h5>

                </div>

                <div class="card-body">

                    <p>

                        <strong>Email:</strong>

                        <%= resident.username %>

                    </p>

                    <% if(resident.isEmailVerified){ %>

                        <span class="badge bg-success">

                            Verified

                        </span>

                    <% } else { %>

                        <span class="badge bg-danger">

                            Not Verified

                        </span>

                    <% } %>

                </div>

            </div>

        </div>

        <!-- Phone -->

        <div class="col-lg-6">

            <div class="card shadow-sm h-100">

                <div class="card-header bg-light">

                    <h5 class="mb-0">

                        <i class="fas fa-phone text-success me-2"></i>

                        Phone Verification

                    </h5>

                </div>

                <div class="card-body">

                    <p>

                        <strong>Phone:</strong>

                        <%= resident.phoneNumber || "Not Added" %>

                    </p>

                    <% if(resident.isPhoneVerified){ %>

                        <span class="badge bg-success">

                            Verified

                        </span>

                    <% } else { %>

                        <span class="badge bg-warning text-dark">

                            Not Verified

                        </span>

                    <% } %>

                </div>

            </div>

        </div>

                <!-- Preferred Login Method -->

        <div class="col-lg-6">

            <div class="card shadow-sm h-100">

                <div class="card-header bg-light">

                    <h5 class="mb-0">

                        <i class="fas fa-sign-in-alt text-info me-2"></i>

                        Preferred Login Method

                    </h5>

                </div>

                <div class="card-body">

                    <form action="/security/login-method" method="POST">

                        <div class="mb-3">

                            <label class="form-label fw-bold">

                                Login Method

                            </label>

                            <select
                                name="loginType"
                                class="form-select">

                                <option
                                    value="password"
                                    <%= resident.loginType==="password" ? "selected" : "" %>>

                                    Email & Password

                                </option>

                                <option
                                    value="google"
                                    <%= resident.loginType==="google" ? "selected" : "" %>>

                                    Google Sign-In

                                </option>

                                <option
                                    value="phone"
                                    <%= resident.loginType==="phone" ? "selected" : "" %>>

                                    Phone OTP

                                </option>

                            </select>

                        </div>

                        <button
                            class="btn btn-primary">

                            <i class="fas fa-save me-2"></i>

                            Update Login Method

                        </button>

                    </form>

                </div>

            </div>

        </div>

<!-- Two Step Verification -->

<div class="col-lg-6">

    <div class="card shadow-sm h-100">

        <div class="card-header bg-light">

            <h5 class="mb-0">

                <i class="fas fa-user-lock text-danger me-2"></i>

                Two-Step Verification

            </h5>

        </div>

        <div class="card-body">

            <form
                action="/security/two-factor"
                method="POST">

                <div class="mb-3">

                    <label class="form-label fw-bold">

                        Verification Method

                    </label>

                    <select
                        name="twoFactorMethod"
                        class="form-select">

                        <option
                            value="disabled"
                            <%= !resident.twoFactorEnabled ? "selected" : "" %>>

                            Disabled

                        </option>

                        <option
                            value="email"
                            <%= resident.twoFactorEnabled && resident.twoFactorMethod==="email" ? "selected" : "" %>>

                            📧 Email OTP

                        </option>

                        <option
                            value="phone"
                            <%= resident.twoFactorEnabled && resident.twoFactorMethod==="phone" ? "selected" : "" %>>

                            📱 Phone OTP

                        </option>

                    </select>

                </div>

                <div class="alert alert-light border">

                    <strong>Current Status</strong>

                    <hr>

                    <% if(resident.twoFactorEnabled){ %>

                        <span class="badge bg-success">

                            Enabled

                        </span>

                        using

                        <strong>

                            <%= resident.twoFactorMethod==="email"
                                ? "Email OTP"
                                : "Phone OTP" %>

                        </strong>

                    <% } else { %>

                        <span class="badge bg-secondary">

                            Disabled

                        </span>

                    <% } %>

                </div>

                <button
                    class="btn btn-danger">

                    <i class="fas fa-save me-2"></i>

                    Save Security

                </button>

            </form>

        </div>

    </div>

</div>

        <!-- Last Login -->

        <div class="col-lg-4">

            <div class="card shadow-sm text-center h-100">

                <div class="card-body">

                    <i class="fas fa-clock fa-3x text-primary mb-3"></i>

                    <h6>

                        Last Login

                    </h6>

                    <p class="text-muted">

                        <%= resident.lastLogin
                            ? new Date(resident.lastLogin).toLocaleString()
                            : "Never Logged In" %>

                    </p>

                </div>

            </div>

        </div>

        <!-- Failed Attempts -->

        <div class="col-lg-4">

            <div class="card shadow-sm text-center h-100">

                <div class="card-body">

                    <i class="fas fa-times-circle fa-3x text-danger mb-3"></i>

                    <h6>

                        Failed Attempts

                    </h6>

                    <h3 class="text-danger">

                        <%= resident.failedLoginAttempts || 0 %>

                    </h3>

                </div>

            </div>

        </div>

        <!-- Account Status -->

        <div class="col-lg-4">

            <div class="card shadow-sm text-center h-100">

                <div class="card-body">

                    <i class="fas fa-user-check fa-3x text-success mb-3"></i>

                    <h6>

                        Account Status

                    </h6>

                    <% if(resident.accountLockedUntil && resident.accountLockedUntil > new Date()){ %>

                        <span class="badge bg-danger px-4 py-2">

                            LOCKED

                        </span>

                    <% } else { %>

                        <span class="badge bg-success px-4 py-2">

                            ACTIVE

                        </span>

                    <% } %>

                </div>

            </div>

        </div>

                <!-- Change Password -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-warning text-dark">

                    <h5 class="mb-0">

                        <i class="fas fa-key me-2"></i>

                        Password

                    </h5>

                </div>

                <div class="card-body">

                    <p class="text-muted">

                        Change your account password regularly
                        to keep your account secure.

                    </p>

                    <a
                        href="/changePassword"
                        class="btn btn-warning">

                        <i class="fas fa-lock me-2"></i>

                        Change Password

                    </a>

                </div>

            </div>

        </div>

        <!-- Login History -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-info text-white">

                    <h5 class="mb-0">

                        <i class="fas fa-history me-2"></i>

                        Login History

                    </h5>

                </div>

                <div class="card-body">

                    <p class="text-muted">

                        View all recent login activity,
                        browser information,
                        devices and login status.

                    </p>

                    <a
                        href="/loginHistory"
                        class="btn btn-info text-white">

                        <i class="fas fa-eye me-2"></i>

                        View Login History

                    </a>

                </div>

            </div>

        </div>

        <!-- Active Sessions -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-success text-white">

                    <h5 class="mb-0">

                        <i class="fas fa-desktop me-2"></i>

                        Current Session

                    </h5>

                </div>

                <div class="card-body">

                    <table class="table table-borderless">

                        <tr>

                            <td>

                                Browser

                            </td>

                        <td>

                            <%= resident.loginHistory &&
                            resident.loginHistory.length > 0
                            ? (resident.loginHistory[
                            resident.loginHistory.length - 1
                            ].browser || "Unknown")
                            : "Unknown" %>

                        </td>

                        </tr>

                        <tr>

                            <td>

                                Device

                            </td>
                        <td>

                            <%= resident.loginHistory &&
                            resident.loginHistory.length > 0
                            ? (resident.loginHistory[
                            resident.loginHistory.length - 1
                            ].device || "Unknown")
                            : "Unknown" %>

                        </td>

                        </tr>

                        <tr>

                            <td>

                                Login Method

                            </td>

                            <td>

                                <%= resident.loginType %>

                            </td>

                        </tr>

                    </table>

                </div>

            </div>

        </div>

        <!-- Security Tips -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-secondary text-white">

                    <h5 class="mb-0">

                        <i class="fas fa-lightbulb me-2"></i>

                        Security Tips

                    </h5>

                </div>

                <div class="card-body">

                    <ul class="mb-0">

                        <li>

                            Enable Two-Step Verification.

                        </li>

                        <li>

                            Use a strong password.

                        </li>

                        <li>

                            Never share your OTP.

                        </li>

                        <li>

                            Regularly review login activity.

                        </li>

                        <li>

                            Logout from shared computers.

                        </li>

                    </ul>

                </div>

            </div>

        </div>

        <!-- Logout From All Devices -->

<div class="col-12">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-danger text-white">

            <h5 class="mb-0">

                <i class="fas fa-sign-out-alt me-2"></i>

                Active Sessions

            </h5>

        </div>

        <div class="card-body">

            <p class="text-muted">

                Logout from every device currently signed into your account.

            </p>

            <form action="/logoutAll" method="POST">

                <button class="btn btn-danger">

                    <i class="fas fa-sign-out-alt me-2"></i>

                    Logout From All Devices

                </button>

            </form>

        </div>

    </div>

</div>

        <!-- Navigation Buttons -->

        <div class="col-12 mt-4">

            <div class="d-flex justify-content-between flex-wrap">

                <a
                    href="/profile"
                    class="btn btn-secondary">

                    <i class="fas fa-arrow-left me-2"></i>

                    Back to Profile

                </a>

                <a
                    href="/logout"
                    class="btn btn-danger">

                    <i class="fas fa-sign-out-alt me-2"></i>

                    Logout

                </a>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<%- include('partials/footer') %>