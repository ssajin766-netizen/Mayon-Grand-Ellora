<!-- ==========================================================
     EMERGENCY CONTACTS
========================================================== -->

<%- include("partials/header") %>

<%

const emergencyContacts = [

{

icon:"fa-wrench",

color:"primary",

title:"Plumbing Service",

value:contact.plumbingService

},

{

icon:"fa-pills",

color:"success",

title:"Pharmacy",

value:contact.medicineShop

},

{

icon:"fa-user-doctor",

color:"info",

title:"Doctor",

value:contact.doctor

},

{

icon:"fa-truck-medical",

color:"danger",

title:"Ambulance",

value:contact.ambulance

},

{

icon:"fa-fire",

color:"danger",

title:"Fire Station",

value:contact.fireStation

},

{

icon:"fa-shield-halved",

color:"dark",

title:"Police Station",

value:contact.policeStation

},

{

icon:"fa-user-shield",

color:"secondary",

title:"Security Guard",

value:contact.guard

},

{

icon:"fa-bolt",

color:"warning",

title:"Electrician",

value:contact.electrician

},

{

icon:"fa-hospital",

color:"danger",

title:"Hospital",

value:contact.hospital

},

{

icon:"fa-elevator",

color:"primary",

title:"Lift Service",

value:contact.liftService

},

{

icon:"fa-droplet",

color:"info",

title:"Water Supply",

value:contact.waterSupply

},

{

icon:"fa-building-shield",

color:"secondary",

title:"Security Office",

value:contact.securityOffice

},

{

icon:"fa-battery-full",

color:"success",

title:"Generator Service",

value:contact.generatorService

},

{

icon:"fa-fire-flame-curved",

color:"warning",

title:"Gas Agency",

value:contact.gasAgency

},

{

icon:"fa-plug-circle-bolt",

color:"warning",

title:"Electricity Board",

value:contact.electricityBoard

},

{

icon:"fa-screwdriver-wrench",

color:"primary",

title:"Maintenance Office",

value:contact.maintenanceOffice

}

];

%>

<div class="container py-5">

    <!-- ====================================== -->

    <div class="text-center mb-5">

        <div class="contact-logo mb-3">

            <img

                src="/images/diversity.png"

                class="img-fluid"

                width="90">

        </div>

        <h2 class="fw-bold">

            <%= society ? society.societyName : "Mayon Grand Ellora" %>

        </h2>

        <p class="text-muted">

            Community Emergency Contacts

        </p>

        <% if(isAdmin){ %>

        <a

            href="/editContacts"

            class="btn btn-primary rounded-pill px-4">

            <i class="fas fa-pen me-2"></i>

            Edit Contacts

        </a>

        <% } %>

    </div>

    <!-- ====================================== -->

    <div class="row g-4">

        <% emergencyContacts.forEach(item=>{ %>

        <div class="col-xl-3 col-lg-4 col-md-6">

            <div class="card contact-card border-0 shadow-sm h-100">

                <div class="card-body text-center">

                    <div class="icon-circle bg-<%= item.color %>">

                        <i

                            class="fas <%= item.icon %>">

                        </i>

                    </div>

                    <h5 class="fw-bold mt-4">

                        <%= item.title %>

                    </h5>

                    <% if(item.value && item.value !== "Not added by admin"){ %>

                    <p class="contact-number">

                        <%= item.value %>

                    </p>

                    <div class="d-grid gap-2">

                        <a

                            href="tel:<%= item.value %>"

                            class="btn btn-success">

                            <i class="fas fa-phone me-2"></i>

                            Call

                        </a>

                    </div>

                    <% }else{ %>

                    <p class="text-muted mt-3">

                        Contact not available

                    </p>

                    <button

                        class="btn btn-secondary"

                        disabled>

                        Not Available

                    </button>

                    <% } %>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>

<style>

.contact-card{

border-radius:20px;

transition:.35s;

overflow:hidden;

}

.contact-card:hover{

transform:translateY(-8px);

box-shadow:0 20px 40px rgba(0,0,0,.15)!important;

}

.contact-card .card-body{

padding:35px 25px;

}

.icon-circle{

width:80px;

height:80px;

border-radius:50%;

display:flex;

justify-content:center;

align-items:center;

margin:auto;

color:#fff;

font-size:32px;

box-shadow:0 10px 20px rgba(0,0,0,.15);

}

.contact-number{

font-size:20px;

font-weight:700;

margin:20px 0;

color:#212529;

word-break:break-word;

}

.contact-logo img{

border-radius:50%;

box-shadow:0 8px 20px rgba(0,0,0,.15);

background:#fff;

padding:10px;

}

.card .btn{

border-radius:50px;

font-weight:600;

}

@media(max-width:768px){

.icon-circle{

width:70px;

height:70px;

font-size:28px;

}

.contact-number{

font-size:18px;

}

}

</style>

<%- include("partials/footer") %>