<%- include('partials/header') %>

<%
const emergencyContacts = [
  { icon: "fa-wrench",       title: "Plumbing Service",   value: contact.plumbingService },
  { icon: "fa-pills",        title: "Pharmacy",           value: contact.medicineShop },
  { icon: "fa-user-md",      title: "Doctor",             value: contact.doctor },
  { icon: "fa-ambulance",    title: "Ambulance",          value: contact.ambulance },
  { icon: "fa-fire-alt",     title: "Fire Station",       value: contact.fireStation },
  { icon: "fa-shield-alt",   title: "Police Station",     value: contact.policeStation },
  { icon: "fa-user-shield",  title: "Guard",              value: contact.guard },
  { icon: "fa-bolt",         title: "Electrician",        value: contact.electrician },
  { icon: "fa-hospital",     title: "Hospital",           value: contact.hospital },
  { icon: "fa-elevator",     title: "Lift Service",       value: contact.liftService },
  { icon: "fa-tint",         title: "Water Supply",       value: contact.waterSupply },
  { icon: "fa-shield-alt",   title: "Security Office",    value: contact.securityOffice },
  { icon: "fa-battery-full", title: "Generator Service",  value: contact.generatorService },
  { icon: "fa-fire",         title: "Gas Agency",         value: contact.gasAgency },
  { icon: "fa-bolt",         title: "Electricity Board",  value: contact.electricityBoard },
  { icon: "fa-tools",        title: "Maintenance Office", value: contact.maintenanceOffice }
];
%>

<div class="container py-4">

    <!-- Header -->
    <div class="text-center mb-5">

        <img src="/images/logo.png"
             alt="Society Logo"
             class="logo-img mb-3">

        <h2 class="society-name">
            <%= society ? society.societyName : "Mayon Grand Ellora" %>
        </h2>

        <p class="page-subtitle">
            Community Management System
        </p>

        <h3 class="page-title">
            <i class="fas fa-phone-alt"></i>
            Emergency Contacts
        </h3>

        <% if(isAdmin){ %>
            <a href="/editContacts" class="btn btn-primary">
                <i class="fas fa-edit"></i>
                Edit Contacts
            </a>
        <% } %>

    </div>

    <!-- Cards -->
    <div class="contact-wrapper">

        <div class="row">

            <% emergencyContacts.forEach(function(item){ %>

            <div class="col-md-6 col-lg-4 mb-4">

                <div class="card emergency-card zoom">

                    <div class="card-header emergency-header">

                        <i class="fas <%= item.icon %>"></i>
                        <strong><%= item.title %></strong>

                    </div>

                    <div class="card-body text-center">

                        <% if(item.value && item.value !== "Not added by admin"){ %>

                            <a href="tel:<%= item.value %>"
                               class="btn btn-success btn-sm">

                                <i class="fas fa-phone"></i>
                                Call Now

                            </a>

                            <div class="phone-number">
                                <%= item.value %>
                            </div>

                        <% } else { %>

                            <span class="text-muted">
                                Not added by admin
                            </span>

                        <% } %>

                    </div>

                </div>

            </div>

            <% }) %>

        </div>

    </div>

</div>

<%- include('partials/footer') %>