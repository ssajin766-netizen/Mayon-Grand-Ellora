<%- include("partials/headerForm") %>

<body class="bg-light">

<div class="container">

    <div class="row justify-content-center">

        <div class="col-lg-5 col-md-7">

            <div class="card shadow-lg border-0 mt-5">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <div class="otp-icon">

                            <i class="fas fa-shield-alt"></i>

                        </div>

                        <h2 class="mt-3">

                            Verify OTP

                        </h2>

                        <p class="text-muted">

                            Enter the verification code sent to

                        </p>

                        <h6 class="text-success">

                            <%= email %>

                        </h6>

                    </div>

                    <% if(error && error.length){ %>

                        <div class="alert alert-danger">

                            <%= error %>

                        </div>

                    <% } %>

                    <% if(success && success.length){ %>

                        <div class="alert alert-success">

                            <%= success %>

                        </div>

                    <% } %>

                    <form
                        action="/verify-reset-otp"
                        method="POST">

                        <div class="form-group">

                            <label>

                                <i class="fas fa-lock text-success mr-2"></i>

                                Enter OTP

                            </label>

                            <input

                                id="otp"

                                type="text"

                                name="otp"

                                maxlength="6"

                                minlength="6"

                                pattern="[0-9]{6}"

                                inputmode="numeric"

                                autocomplete="one-time-code"

                                class="form-control text-center otp-input"

                                placeholder="••••••"

                                required

                            >

                        </div>

                        <button

                            class="btn btn-success btn-lg btn-block mt-4"

                            type="submit">

                            <i class="fas fa-check-circle mr-2"></i>

                            Verify OTP

                        </button>

                    </form>

                    <hr>

                    <!-- Resend -->

                    <form
                        action="/forgot-password"
                        method="POST">

                        <input
                            type="hidden"
                            name="email"
                            value="<%= email %>">

                        <button

                            id="resendBtn"

                            class="btn btn-outline-primary btn-block"

                            disabled>

                            Resend OTP (

                            <span id="timer">

                                60

                            </span>

                            s)

                        </button>

                    </form>

                    <div class="text-center mt-4">

                        <a
                            href="/forgot-password"
                            class="btn btn-secondary">

                            Back

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

const otp = document.getElementById("otp");

otp.focus();

otp.addEventListener("input",function(){

    this.value=this.value.replace(/\D/g,"");

});

let seconds=60;

const timer=document.getElementById("timer");

const resend=document.getElementById("resendBtn");

const interval=setInterval(()=>{

    seconds--;

    timer.innerText=seconds;

    if(seconds<=0){

        clearInterval(interval);

        resend.disabled=false;

        resend.innerHTML='<i class="fas fa-redo mr-2"></i>Resend OTP';

    }

},1000);

</script>

<style>

body{

    background:#f4f7fb;

}

.card{

    border-radius:20px;

}

.card-body{

    padding:40px;

}

.otp-icon{

    width:80px;

    height:80px;

    margin:auto;

    border-radius:50%;

    background:#eaf8ef;

    display:flex;

    justify-content:center;

    align-items:center;

}

.otp-icon i{

    font-size:34px;

    color:#198754;

}

.otp-input{

    font-size:28px;

    letter-spacing:12px;

    font-weight:700;

    height:60px;

    border-radius:12px;

}

.form-control:focus{

    border-color:#198754;

    box-shadow:0 0 0 .2rem rgba(25,135,84,.15);

}

.btn{

    height:48px;

    border-radius:12px;

    font-weight:600;

}

</style>

</body>

</html>