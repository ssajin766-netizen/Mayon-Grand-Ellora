<%- include("partials/headerForm") %>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<div class="verify-wrapper">

    <div class="verify-card">

        <div class="text-center mb-4">

            <div class="logo-circle">

                <i class="fas fa-envelope-open-text"></i>

            </div>

            <h2 class="mt-4">

                Verify OTP

            </h2>

            <p class="text-muted mb-1">

                Enter the verification code sent to

            </p>

            <h6 class="email">

                <%= email %>

            </h6>

        </div>

        <% if(error && error.length){ %>

            <div class="alert alert-danger">

                <%= error %>

            </div>

        <% } %>

        <% if(success && success.length){ %>

            <div class="alert alert-success">

                <%= success %>

            </div>

        <% } %>

        <form
            id="otpForm"
            action="/verify-reset-otp"
            method="POST">

            <input
                type="hidden"
                id="otp"
                name="otp">

            <div class="otp-container">

                <input maxlength="1" class="otp-box" autofocus>

                <input maxlength="1" class="otp-box">

                <input maxlength="1" class="otp-box">

                <input maxlength="1" class="otp-box">

                <input maxlength="1" class="otp-box">

                <input maxlength="1" class="otp-box">

            </div>

            <button
                id="verifyBtn"
                class="btn btn-success w-100 mt-4">

                <i class="fas fa-check-circle me-2"></i>

                Verify OTP

            </button>

        </form>

        <div class="countdown mt-4">

            Resend OTP in

            <span id="timer">

                60

            </span>

            sec

        </div>

        <form
            action="/forgot-password"
            method="POST"
            class="mt-3">

            <input
                type="hidden"
                name="email"
                value="<%= email %>">

            <button
                id="resendBtn"
                class="btn btn-light w-100"
                disabled>

                <i class="fas fa-redo me-2"></i>

                Resend OTP

            </button>

        </form>

        <a
            href="/forgot-password"
            class="btn btn-outline-secondary w-100 mt-3">

            <i class="fas fa-arrow-left me-2"></i>

            Back

        </a>

    </div>

</div>

<script>

const boxes=document.querySelectorAll(".otp-box");
const hidden=document.getElementById("otp");
const form=document.getElementById("otpForm");
const btn=document.getElementById("verifyBtn");

boxes.forEach((box,index)=>{

    box.addEventListener("input",function(){

        this.value=this.value.replace(/\D/g,"");

        if(this.value && index<5){

            boxes[index+1].focus();

        }

        hidden.value=[...boxes].map(x=>x.value).join("");

        if(hidden.value.length===6){

            btn.disabled=true;

            btn.innerHTML=
            '<span class="spinner-border spinner-border-sm me-2"></span>Verifying...';

            form.submit();

        }

    });

    box.addEventListener("keydown",function(e){

        if(e.key==="Backspace" && !this.value && index>0){

            boxes[index-1].focus();

        }

    });

});

document.addEventListener("paste",function(e){

    const text=e.clipboardData.getData("text").replace(/\D/g,"");

    if(text.length===6){

        boxes.forEach((box,i)=>{

            box.value=text[i];

        });

        hidden.value=text;

        form.submit();

    }

});

let seconds=60;

const timer=document.getElementById("timer");

const resend=document.getElementById("resendBtn");

const interval=setInterval(()=>{

    seconds--;

    timer.innerText=seconds;

    if(seconds<=0){

        clearInterval(interval);

        resend.disabled=false;

        resend.classList.remove("btn-light");

        resend.classList.add("btn-success");

        timer.innerText="0";

    }

},1000);

</script>

<style>

body{

    background:#f3f5f7;

    font-family:'Inter',sans-serif;

}

.verify-wrapper{

    min-height:100vh;

    display:flex;

    justify-content:center;

    align-items:center;

    padding:30px;

}

.verify-card{

    width:100%;

    max-width:470px;

    background:#fff;

    border-radius:28px;

    padding:40px;

    box-shadow:0 20px 50px rgba(0,0,0,.08);

    animation:fadeUp .4s ease;

}

.logo-circle{

    width:90px;

    height:90px;

    margin:auto;

    border-radius:50%;

    background:#25D366;

    display:flex;

    justify-content:center;

    align-items:center;

    color:#fff;

    font-size:40px;

    box-shadow:0 10px 25px rgba(37,211,102,.25);

}

.email{

    color:#25D366;

    font-weight:600;

    word-break:break-word;

}

.otp-container{

    display:flex;

    justify-content:space-between;

    margin-top:30px;

}

.otp-box{

    width:58px;

    height:64px;

    border-radius:16px;

    border:2px solid #ddd;

    text-align:center;

    font-size:28px;

    font-weight:700;

    transition:.2s;

}

.otp-box:focus{

    outline:none;

    border-color:#25D366;

    box-shadow:0 0 0 .2rem rgba(37,211,102,.15);

}

.btn{

    height:54px;

    border-radius:16px;

    font-weight:600;

}

.btn-success{

    background:#25D366;

    border:none;

}

.btn-success:hover{

    background:#1ebe5d;

}

.countdown{

    text-align:center;

    color:#777;

}

.alert{

    border-radius:14px;

}

@keyframes fadeUp{

    from{

        opacity:0;

        transform:translateY(20px);

    }

    to{

        opacity:1;

        transform:none;

    }

}

@media(max-width:480px){

    .verify-card{

        padding:25px;

    }

    .otp-box{

        width:45px;

        height:55px;

        font-size:22px;

    }

}

</style>

<%- include("partials/footer") %>