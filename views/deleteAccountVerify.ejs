<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Verify Account Deletion</title>

    <link rel="stylesheet" href="/styles.css">

</head>

<body>

<div class="container">

    <div class="card">

        <h2>Verify Your Identity</h2>

        <p>
            Before deleting your account, we need to verify that it's really you.
        </p>

        <p>
            We will send a One-Time Password (OTP) to:
        </p>

        <h4><%= user.username %></h4>

        <% if(success.length){ %>

            <div class="alert alert-success">
                <%= success %>
            </div>

        <% } %>

        <% if(error.length){ %>

            <div class="alert alert-danger">
                <%= error %>
            </div>

        <% } %>

        <form action="/delete-account/send-otp" method="POST">

            <button
                type="submit"
                class="btn btn-danger w-100">

                Send Verification Code

            </button>

        </form>

        <br>

        <a href="/delete-account" class="btn btn-secondary">

            Back

        </a>

    </div>

</div>

</body>

</html>