<%- include('partials/headerForm') %>

<body>

<div class="container">

    <div class="row justify-content-center">

        <div class="col-lg-6 col-md-8 col-sm-10">

            <div class="card card-signin shadow-lg">

                <div class="card-body">

                    <div class="text-center mb-4">

                        <div class="signup-icon">

                            <i class="fas fa-user-plus"></i>

                        </div>

                        <h2 class="mt-3">

                            Create Account

                        </h2>

                        <p class="text-muted">

                            Join Mayon Grand Ellora

                        </p>

                    </div>

                    <form
                    id="signupForm"
                    action="/signup"
                    method="POST">

                        <div class="form-label-group">

                            <input
                            name="firstName"
                            type="text"
                            class="form-control"
                            placeholder="First Name"
                            required>

                            <label>

                                First Name

                            </label>

                        </div>

                        <div class="form-label-group">

                            <input
                            name="lastName"
                            type="text"
                            class="form-control"
                            placeholder="Last Name"
                            required>

                            <label>

                                Last Name

                            </label>

                        </div>

                        <!-- PHONE -->

                        <div class="form-group mb-4">

                            <label>

                                <i class="fas fa-phone text-success"></i>

                                Mobile Number

                            </label>

                            <input
                            id="phone"
                            type="tel"
                            class="form-control"
                            autocomplete="tel"
                            required>

                            <input
                            type="hidden"
                            id="phoneNumber"
                            name="phoneNumber">

                            <small class="text-muted">

                                Select your country and enter your mobile number.

                            </small>

                        </div>

                        <div class="form-label-group">

                            <input
                            name="societyName"
                            list="societyList"
                            class="form-control"
                            placeholder="Society Name"
                            required>

                            <datalist id="societyList">

                                <% societies.forEach(society=>{ %>

                                <option value="<%= society.societyName %>">

                                <% }) %>

                            </datalist>

                            <label>

                                Society Name

                            </label>

                        </div>

                        <div class="form-label-group">

                            <input
                            name="flatNumber"
                            type="text"
                            class="form-control"
                            placeholder="Flat Number"
                            required>

                            <label>

                                Flat Number

                            </label>

                        </div>

                        <div class="form-label-group">

                            <input
                            name="username"
                            type="email"
                            class="form-control"
                            placeholder="Email"
                            required>

                            <label>

                                Email Address

                            </label>

                        </div>

                        <div class="form-label-group">

                            <input
                            name="password"
                            type="password"
                            class="form-control"
                            placeholder="Password"
                            required>

                            <label>

                                Password

                            </label>

                        </div>

                        <button
                        class="btn btn-success btn-lg btn-block mt-4"
                        type="submit">

                            <i class="fas fa-user-plus"></i>

                            Create Account

                        </button>

                        <div class="text-center my-4">

                            <strong>

                                OR

                            </strong>

                        </div>

                        <a
                        href="/auth/google"
                        class="btn btn-light btn-block google-btn">

                            <img
                            src="https://developers.google.com/identity/images/g-logo.png"
                            width="20">

                            Continue with Google

                        </a>

                        <hr>

                        <a
                        href="/login"
                        class="btn btn-outline-primary btn-block">

                            Sign In

                        </a>

                        <a
                        href="/"
                        class="btn btn-secondary btn-block mt-2">

                            Home

                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- jQuery (Required) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Intl Tel Input -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/18.2.1/js/intlTelInput.min.js"></script>

<script>

const phoneInput = document.querySelector("#phone");

const hiddenPhone = document.querySelector("#phoneNumber");

const iti = window.intlTelInput(phoneInput,{

    initialCountry:"in",

    preferredCountries:[
        "in",
        "us",
        "gb",
        "ae",
        "sg",
        "my",
        "lk"
    ],

    separateDialCode:true,

    nationalMode:false,

    autoPlaceholder:"aggressive",

    utilsScript:"https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/18.2.1/js/utils.js"

});

$("#signupForm").on("submit",function(e){

    e.preventDefault();

    const phone = iti.getNumber();

    if(!iti.isValidNumber()){

        alert("Please enter a valid phone number.");

        return;

    }

    hiddenPhone.val = phone;

    document.getElementById("phoneNumber").value = phone;

    this.submit();

});

</script>

<style>

body{

    background:#f5f7fb;

}

.card-signin{

    border:none;

    border-radius:18px;

    margin:40px auto;

}

.card-body{

    padding:40px;

}

.signup-icon{

    width:70px;

    height:70px;

    margin:auto;

    border-radius:50%;

    background:#e9f8ee;

    display:flex;

    justify-content:center;

    align-items:center;

}

.signup-icon i{

    font-size:30px;

    color:#28a745;

}

.iti{

    width:100%;

}

.iti input{

    width:100%!important;

    height:48px;

}

.iti__country-list{

    z-index:999999;

}

.google-btn{

    display:flex;

    justify-content:center;

    align-items:center;

    gap:10px;

}

</style>

</body>

</html>