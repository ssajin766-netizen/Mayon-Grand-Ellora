<!-- ==========================================================
     USER SIGN UP
========================================================== -->

<%- include("partials/headerForm") %>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/css/intlTelInput.css">

<link
href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
rel="stylesheet">

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-xl-7 col-lg-8 col-md-10">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- Header -->

                <div class="card-header bg-success text-white text-center py-4 border-0">

                    <div class="signup-icon">

                        <i class="fas fa-user-plus"></i>

                    </div>

                    <h2 class="fw-bold mt-3">

                        Create Account

                    </h2>

                    <p class="mb-0 opacity-75">

                        Join Mayon Grand Ellora Community

                    </p>

                </div>

                <!-- Body -->

                <div class="card-body p-5">

                    <% if(success && success.length){ %>

                        <div class="alert alert-success">

                            <i class="fas fa-check-circle me-2"></i>

                            <%= success %>

                        </div>

                    <% } %>

                    <% if(error && error.length){ %>

                        <div class="alert alert-danger">

                            <i class="fas fa-times-circle me-2"></i>

                            <%= error %>

                        </div>

                    <% } %>

                    <form
                        id="signupForm"
                        action="/signup"
                        method="POST">

                        <!-- Personal Information -->

                        <h5 class="section-title">

                            Personal Information

                        </h5>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label class="form-label">

                                    First Name

                                </label>

                                <input
                                    type="text"
                                    id="firstName"
                                    name="firstName"
                                    class="form-control"
                                    placeholder="Enter first name"
                                    required>

                            </div>

                            <div class="col-md-6 mb-3">

                                <label class="form-label">

                                    Last Name

                                </label>

                                <input
                                    type="text"
                                    id="lastName"
                                    name="lastName"
                                    class="form-control"
                                    placeholder="Enter last name"
                                    required>

                            </div>

                        </div>

                        <div class="mb-4">

                            <label class="form-label">

                                Mobile Number

                            </label>

                            <input
                                id="phone"
                                type="tel"
                                class="form-control"
                                autocomplete="tel"
                                required>

                            <input
                                type="hidden"
                                id="phoneNumber"
                                name="phoneNumber">

                        </div>

                        <!-- Society Information -->

                        <h5 class="section-title">

                            Society Information

                        </h5>

                        <div class="mb-3">

                            <label class="form-label">

                                Society Name

                            </label>

                            <input
                                id="societyName"
                                name="societyName"
                                list="societyList"
                                class="form-control"
                                placeholder="Select your society"
                                autocomplete="off"
                                required>

                            <datalist id="societyList">

                                <% societies.forEach(function(society){ %>

                                    <option value="<%= society.societyName %>">

                                <% }) %>

                            </datalist>

                        </div>

                        <div class="mb-4">

                            <label class="form-label">

                                Flat Number

                            </label>

                            <input
                                id="flatNumber"
                                name="flatNumber"
                                type="text"
                                class="form-control"
                                placeholder="Example: A-101"
                                required>

                        </div>

                        <!-- Account -->

                        <h5 class="section-title">

                            Account Information

                        </h5>

                        <div class="mb-3">

                            <label class="form-label">

                                Email Address

                            </label>

                            <input
                                id="email"
                                name="username"
                                type="email"
                                class="form-control"
                                placeholder="Enter your email"
                                required>

                        </div>

                        <div class="mb-4">

                            <label class="form-label">

                                Password

                            </label>

                            <input
                                id="password"
                                name="password"
                                type="password"
                                class="form-control"
                                placeholder="Create a password"
                                required>

                        </div>

                        <!-- Register -->

                        <button
                            id="submitBtn"
                            type="submit"
                            class="btn btn-success w-100">

                            <i class="fas fa-user-plus me-2"></i>

                            Create Account

                        </button>

                    </form>

                    <div class="divider">

                        <span>OR</span>

                    </div>

                    <!-- Google -->

                    <a
                        href="/auth/google"
                        class="btn btn-light w-100 google-btn">

                        <img
                            src="https://developers.google.com/identity/images/g-logo.png"
                            width="20">

                        Continue with Google

                    </a>

                    <!-- Phone -->

                    <a
                        href="/loginPhone"
                        class="btn btn-success w-100 mt-3">

                        <i class="fas fa-mobile-alt me-2"></i>

                        Continue with Phone

                    </a>

                    <hr>

                    <p class="text-center text-muted">

                        Already have an account?

                    </p>

                    <a
                        href="/login"
                        class="btn btn-outline-primary w-100">

                        Login

                    </a>

                    <a
                        href="/"
                        class="btn btn-outline-secondary w-100 mt-3">

                        Back to Home

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/intlTelInput.min.js"></script>

<script>

const phoneInput=document.querySelector("#phone");
const hiddenPhone=document.querySelector("#phoneNumber");
const form=document.querySelector("#signupForm");
const submitBtn=document.querySelector("#submitBtn");

const iti=window.intlTelInput(phoneInput,{

    initialCountry:"in",

    preferredCountries:[
        "in",
        "us",
        "gb",
        "ae",
        "sg",
        "my",
        "lk"
    ],

    separateDialCode:true,

    nationalMode:false,

    autoPlaceholder:"aggressive",

    formatOnDisplay:true,

    loadUtils:()=>import(
"https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/utils.js")

});

form.addEventListener("submit",function(e){

    e.preventDefault();

    if(!iti.isValidNumber()){

        alert("Please enter a valid phone number.");

        phoneInput.focus();

        return;

    }

    hiddenPhone.value=iti.getNumber();

    submitBtn.disabled=true;

    submitBtn.innerHTML=`
        <span class="spinner-border spinner-border-sm me-2"></span>
        Creating Account...
    `;

    this.submit();

});

</script>

<style>

body{

    background:#f4f7fb;

    font-family:'Inter',sans-serif;

}

.signup-icon{

    width:90px;

    height:90px;

    margin:auto;

    border-radius:50%;

    background:#ffffff22;

    display:flex;

    justify-content:center;

    align-items:center;

}

.signup-icon i{

    font-size:40px;

    color:#fff;

}

.section-title{

    font-weight:700;

    margin-bottom:20px;

    color:#343a40;

    border-left:5px solid #198754;

    padding-left:12px;

}

.card{

    border-radius:24px;

}

.form-control{

    min-height:52px;

    border-radius:14px;

    border:2px solid #e5e7eb;

}

.form-control:focus{

    border-color:#198754;

    box-shadow:0 0 0 .2rem rgba(25,135,84,.15);

}

.iti{

    width:100%;

}

.iti input{

    width:100%!important;

    min-height:52px;

    border-radius:14px;

}

.iti__country-list{

    border-radius:12px;

    z-index:999999;

    box-shadow:0 10px 30px rgba(0,0,0,.15);

}

.btn{

    min-height:50px;

    border-radius:14px;

    font-weight:600;

}

.google-btn{

    display:flex;

    justify-content:center;

    align-items:center;

    gap:10px;

    border:1px solid #dee2e6;

}

.google-btn:hover{

    background:#f8f9fa;

}

.divider{

    display:flex;

    align-items:center;

    margin:30px 0;

}

.divider::before,

.divider::after{

    content:"";

    flex:1;

    height:1px;

    background:#dee2e6;

}

.divider span{

    padding:0 15px;

    color:#6c757d;

    font-weight:600;

}

@media(max-width:768px){

    .card-body{

        padding:30px 22px;

    }

}

</style>

<%- include("partials/footer") %>