<%- include('partials/headerForm') %>

<body style="background:#f5f7fb;">

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-6 col-md-8">

            <div class="card shadow border-0 rounded">

                <div class="card-body p-4">

                    <div class="text-center mb-4">

                        <i class="fas fa-user-plus fa-3x text-success mb-3"></i>

                        <h2>Create Account</h2>

                        <p class="text-muted">
                            Join Mayon Grand Ellora
                        </p>

                    </div>

                    <form id="signupForm"
                          action="/signup"
                          method="POST">

                        <!-- First Name -->

                        <div class="form-group">

                            <label for="firstName">
                                First Name
                            </label>

                            <input
                                id="firstName"
                                name="firstName"
                                type="text"
                                class="form-control"
                                required>

                        </div>

                        <!-- Last Name -->

                        <div class="form-group">

                            <label for="lastName">
                                Last Name
                            </label>

                            <input
                                id="lastName"
                                name="lastName"
                                type="text"
                                class="form-control"
                                required>

                        </div>

                        <!-- Phone -->

                        <div class="form-group">

                            <label for="phone">
                                Mobile Number
                            </label>

                            <input
                                id="phone"
                                type="tel"
                                class="form-control"
                                autocomplete="tel"
                                required>

                            <input
                                type="hidden"
                                id="phoneNumber"
                                name="phoneNumber">

                        </div>

                        <!-- Society -->

                        <div class="form-group">

                            <label for="societyName">
                                Society Name
                            </label>

                            <input
                                id="societyName"
                                name="societyName"
                                list="societyList"
                                class="form-control"
                                autocomplete="off"
                                required>

                            <datalist id="societyList">

                                <% societies.forEach(function(society){ %>

                                    <option value="<%= society.societyName %>">

                                <% }) %>

                            </datalist>

                        </div>

                        <!-- Flat -->

                        <div class="form-group">

                            <label for="flatNumber">
                                Flat Number
                            </label>

                            <input
                                id="flatNumber"
                                name="flatNumber"
                                type="text"
                                class="form-control"
                                required>

                        </div>

                        <!-- Email -->

                        <div class="form-group">

                            <label for="email">
                                Email Address
                            </label>

                            <input
                                id="email"
                                name="username"
                                type="email"
                                class="form-control"
                                required>

                        </div>

                        <!-- Password -->

                        <div class="form-group">

                            <label for="password">
                                Password
                            </label>

                            <input
                                id="password"
                                name="password"
                                type="password"
                                class="form-control"
                                required>

                        </div>

                        <button
                            class="btn btn-success btn-block btn-lg mt-4">

                            <i class="fas fa-user-plus"></i>

                            Create Account

                        </button>

                        <div class="text-center my-4">

                            <strong>OR</strong>

                        </div>

                        <a
                            href="/auth/google"
                            class="btn btn-light btn-block"
                            style="border:1px solid #ddd;display:flex;justify-content:center;align-items:center;gap:10px;">

                            <img
                                src="https://developers.google.com/identity/images/g-logo.png"
                                width="20">

                            Continue with Google

                        </a>

                        <hr>

                        <a
                            href="/login"
                            class="btn btn-outline-primary btn-block">

                            Sign In

                        </a>

                        <a
                            href="/"
                            class="btn btn-secondary btn-block mt-2">

                            Home

                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@18.1.8/build/js/intlTelInput.min.js"></script>

<script>

const phoneInput = document.querySelector("#phone");

const iti = window.intlTelInput(phoneInput,{

    initialCountry:"in",

    preferredCountries:[
        "in",
        "us",
        "gb",
        "ae",
        "sg",
        "my",
        "lk"
    ],

    separateDialCode:true,

    nationalMode:false,

    autoPlaceholder:"aggressive",

    utilsScript:"https://cdn.jsdelivr.net/npm/intl-tel-input@18.1.8/build/js/utils.js"

});

document
.getElementById("signupForm")
.addEventListener("submit",function(e){

    e.preventDefault();

    const phone = iti.getNumber();

    if(!phone.startsWith("+")){

        alert("Please enter a valid phone number.");

        return;

    }

    document.getElementById("phoneNumber").value = phone;

    this.submit();

});

</script>

<style>

body{

    background:#f5f7fb;

}

.card{

    border-radius:18px;

}

.form-control{

    height:46px;

    border-radius:10px;

}

.btn{

    border-radius:10px;

}

.iti{

    width:100%;

}

.iti input{

    width:100%!important;

    height:46px;

}

.iti__country-list{

    z-index:999999;

}

</style>

</body>

</html>