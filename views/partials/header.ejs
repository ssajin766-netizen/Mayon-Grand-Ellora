<!DOCTYPE html>
<html lang="en">

<head>

    <title>Mayon Grand Ellora</title>

    <meta charset="utf-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1">

    <meta
        name="description"
        content="Simplify everyday living for your housing society!">

    <meta
        name="google-site-verification"
        content="P8hqAw19_O3IT82LJYjlEsI9TDS9vMATQkZXKoe2M8E">

    <link
        rel="shortcut icon"
        href="/images/favicon.ico">

    <!-- Bootstrap 5 -->

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <!-- Font Awesome -->

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <!-- W3 CSS -->

    <link
        rel="stylesheet"
        href="https://www.w3schools.com/w3css/4/w3.css">

    <!-- International Phone Input -->

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/css/intlTelInput.css">

    <!-- Project CSS -->

    <link
        rel="stylesheet"
        href="/styles.css">

    <!-- Libraries -->

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.2/html2pdf.bundle.min.js"></script>

    <script src="https://js.stripe.com/v3/"></script>

    <script src="/pdf-generator.js"></script>

    <%- include("../scripts/adsense") %>

    <%- include("../scripts/tagManager") %>

</head>

<body>

<% if (typeof hideNavbar === "undefined" || !hideNavbar) { %>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">

    <div class="container">

        <a
            class="navbar-brand d-flex align-items-center"
            href="/home">

            <img
                src="/images/diversity.png"
                width="42"
                height="42"
                class="rounded-circle me-2"
                alt="Logo">

            <strong>Mayon Grand Ellora</strong>

        </a>

        <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNavbar">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div
            class="collapse navbar-collapse"
            id="mainNavbar">

            <ul class="navbar-nav me-auto">

                <li class="nav-item">
                    <a class="nav-link" href="/home">
                        <i class="fas fa-home me-1"></i> Home
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/residents">
                        <i class="fas fa-users me-1"></i> Residents
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/noticeboard">
                        <i class="fas fa-bullhorn me-1"></i> Noticeboard
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/bill">
                        <i class="fas fa-file-invoice-dollar me-1"></i> Bills
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/helpdesk">
                        <i class="fas fa-headset me-1"></i> Helpdesk
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/contacts">
                        <i class="fas fa-phone-alt me-1"></i> Emergency
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/profile">
                        <i class="fas fa-user-circle me-1"></i> Profile
                    </a>
                </li>

            </ul>

            <ul class="navbar-nav align-items-center">

    <!-- Notifications -->

    <li class="nav-item me-2">

        <a
            class="nav-link position-relative"
            href="/notifications"
            title="Notifications">

            <i class="fas fa-bell fa-lg"></i>

            <% if (unreadNotifications > 0) { %>

               <span
                 class="notification-badge position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">

                  <%= unreadNotifications %>

                </span>

            <% } %>

        </a>

    </li>

    <!-- Logout -->

    <li class="nav-item">

        <a
            class="nav-link text-danger"
            href="/logout">

            <i class="fas fa-sign-out-alt me-1"></i>

            Logout

        </a>

    </li>

</ul>

        </div>

    </div>

</nav>


<% } %>