<!-- Form Header -->
<!DOCTYPE html>
<html lang="en">

<head>

    <title>Mayon Grand Ellora</title>

    <meta charset="utf-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <meta
        name="description"
        content="Simplify everyday living for your housing society!">

    <link
        rel="shortcut icon"
        href="/images/favicon.ico">

    <!-- Bootstrap -->

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/css/bootstrap.min.css">

    <!-- Font Awesome -->

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <!-- International Phone Input -->

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/intl-tel-input@18.1.8/build/css/intlTelInput.css">

    <style>

    body{

        background:#f4f7fb;

        font-family:'Segoe UI',sans-serif;

    }

    .container{

        padding-top:40px;

        padding-bottom:40px;

    }

    .card-signin{

        border:none;

        border-radius:18px;

        box-shadow:0 12px 30px rgba(0,0,0,.08);

        overflow:hidden;

    }

    .card-body{

        padding:35px;

    }

    .signup-icon{

        width:75px;

        height:75px;

        background:#e8f7ee;

        border-radius:50%;

        display:flex;

        justify-content:center;

        align-items:center;

        margin:auto;

    }

    .signup-icon i{

        color:#28a745;

        font-size:34px;

    }

    h2{

        font-weight:700;

    }

    .text-muted{

        font-size:14px;

    }

    .form-group{

        margin-bottom:18px;

    }

    .form-group label{

        font-weight:600;

        color:#555;

        margin-bottom:8px;

    }

    .form-control{

        height:48px;

        border-radius:10px;

        border:1px solid #d9d9d9;

        font-size:15px;

        box-shadow:none;

    }

    .form-control:focus{

        border-color:#28a745;

        box-shadow:0 0 0 .2rem rgba(40,167,69,.15);

    }

    .btn{

        height:48px;

        border-radius:10px;

        font-weight:600;

        font-size:15px;

    }

    .google-btn{

        display:flex;

        justify-content:center;

        align-items:center;

        gap:10px;

        border:1px solid #dadce0;

        background:#fff;

    }

    .google-btn:hover{

        background:#f8f9fa;

    }

    /* ==========================
       International Phone Input
       ========================== */

    .iti{

        width:100%;

        display:block;

    }

    .iti__flag-container{

        z-index:100;

    }

    .iti__country-list{

        z-index:999999;

        max-height:250px;

        width:330px;

    }

    .iti input{

        width:100%!important;

        height:48px;

        border-radius:10px;

        padding-left:95px!important;

    }

    .iti--allow-dropdown input{

        padding-left:95px!important;

    }

    .iti__selected-flag{

        border-radius:10px 0 0 10px;

    }

    small{

        display:block;

        margin-top:6px;

    }

    @media(max-width:768px){

        .card-body{

            padding:25px;

        }

    }

    </style>

    <%- include('../scripts/tagManager') %>

</head>