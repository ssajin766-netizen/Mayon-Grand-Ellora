<!-- ==========================================================
     FORM HEADER
========================================================== -->

<!DOCTYPE html>
<html lang="en">

<head>

    <title>Mayon Grand Ellora</title>

    <meta charset="utf-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1">

    <meta
        name="description"
        content="Simplify everyday living for your housing society!">

    <link
        rel="shortcut icon"
        href="/images/favicon.ico">

    <!-- ======================================================
         Bootstrap 5
    ======================================================= -->

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <!-- ======================================================
         Font Awesome
    ======================================================= -->

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <!-- ======================================================
         International Phone Input
    ======================================================= -->

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/css/intlTelInput.css">

    <!-- ======================================================
         Project CSS
    ======================================================= -->

    <link
        rel="stylesheet"
        href="/styles.css">

    <!-- ======================================================
         Page Styles
    ======================================================= -->

    <style>

    body{

        background:#f4f7fb;

        font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;

    }

    .container{

        padding-top:50px;

        padding-bottom:50px;

    }

    .card-signin{

        border:none;

        border-radius:22px;

        overflow:hidden;

        background:#fff;

        box-shadow:0 15px 40px rgba(0,0,0,.08);

    }

    .card-body{

        padding:40px;

    }

    .signup-icon{

        width:80px;

        height:80px;

        border-radius:50%;

        background:#e8f7ee;

        display:flex;

        justify-content:center;

        align-items:center;

        margin:auto;

        box-shadow:0 8px 20px rgba(25,135,84,.12);

    }

    .signup-icon i{

        color:#198754;

        font-size:34px;

    }

    h2{

        font-weight:700;

        color:#212529;

    }

    .text-muted{

        font-size:15px;

    }

    .form-group{

        margin-bottom:20px;

    }

    .form-group label{

        font-weight:600;

        color:#495057;

        margin-bottom:8px;

    }

    .form-control{

        height:50px;

        border-radius:12px;

        border:1px solid #d9d9d9;

        font-size:15px;

        box-shadow:none;

        transition:.3s;

    }

    .form-control:focus{

        border-color:#198754;

        box-shadow:0 0 0 .2rem rgba(25,135,84,.15);

    }

    .btn{

        height:50px;

        border-radius:12px;

        font-weight:600;

        font-size:15px;

    }

    .btn-success{

        background:#198754;

        border:none;

    }

    .btn-success:hover{

        background:#157347;

    }

    .btn-outline-secondary{

        border-radius:12px;

    }

    .google-btn{

        display:flex;

        justify-content:center;

        align-items:center;

        gap:10px;

        background:#fff;

        border:1px solid #dadce0;

    }

    .google-btn:hover{

        background:#f8f9fa;

    }

    /* ===========================================
       International Phone Input
    ============================================ */

    .iti{

        width:100%;

    }

    .iti input{

        width:100%!important;

        height:50px;

        border-radius:12px;

        padding-left:95px!important;

    }

    .iti__country-list{

        z-index:999999;

        border-radius:12px;

        box-shadow:0 10px 30px rgba(0,0,0,.15);

    }

    .iti__flag-container{

        z-index:100;

    }

    .iti__selected-country{

        padding:0 12px;

    }

    small{

        display:block;

        margin-top:6px;

    }

    /* ===========================================
       Alerts
    ============================================ */

    .alert{

        border-radius:12px;

    }

    /* ===========================================
       Responsive
    ============================================ */

    @media(max-width:768px){

        .container{

            padding-top:25px;

        }

        .card-body{

            padding:25px;

        }

        h2{

            font-size:28px;

        }

    }

    </style>

    <%- include("../scripts/tagManager") %>

</head>