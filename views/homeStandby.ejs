<!-- ==========================================================
     ACCOUNT STATUS
========================================================== -->

<%- include("partials/header") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-6 col-md-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-body text-center p-5">

                    <!-- Status Icon -->

                    <div class="status-icon mb-4">

                        <i class="fas <%= icon %>"></i>

                    </div>

                    <!-- Title -->

                    <h2 class="fw-bold mb-3">

                        <%= title %>

                    </h2>

                    <!-- Message -->

                    <p class="text-muted fs-5 mb-4">

                        <%= content %>

                    </p>

                    <% if(title === "Account Pending"){ %>

                        <div class="alert alert-warning rounded-3">

                            <i class="fas fa-clock me-2"></i>

                            Your registration request has been submitted successfully.
                            Please wait until the society administrator approves your account.

                        </div>

                    <% } %>

                    <% if(title === "Account Declined"){ %>

                        <div class="alert alert-danger rounded-3">

                            <i class="fas fa-circle-xmark me-2"></i>

                            Your request has been declined.
                            Please contact the society administrator for more information.

                        </div>

                    <% } %>

                    <!-- Buttons -->

                    <div class="d-flex justify-content-center gap-3 flex-wrap mt-4">

                        <a
                            href="/logout"
                            class="btn btn-outline-danger px-4">

                            <i class="fas fa-sign-out-alt me-2"></i>

                            Logout

                        </a>

                        <a
                            href="/newRequest"
                            class="btn btn-primary px-4">

                            <i class="fas fa-file-alt me-2"></i>

                            New Request

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

.status-icon{

    width:120px;

    height:120px;

    margin:auto;

    border-radius:50%;

    background:#eef4ff;

    display:flex;

    justify-content:center;

    align-items:center;

    box-shadow:0 10px 25px rgba(13,110,253,.15);

}

.status-icon i{

    font-size:56px;

    color:#0d6efd;

}

.card{

    border-radius:22px;

}

.alert{

    border:none;

}

.btn{

    min-width:170px;

    border-radius:12px;

    font-weight:600;

}

@media(max-width:768px){

    .status-icon{

        width:100px;

        height:100px;

    }

    .status-icon i{

        font-size:46px;

    }

}

</style>

<%- include("partials/footer") %>