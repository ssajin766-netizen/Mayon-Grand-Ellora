<%- include("partials/header") %>

<div class="container py-4">

    <!-- =========================================
         Page Header
    ========================================== -->

    <div class="text-center mb-5">

        <h2 class="fw-bold">

            <i class="fas fa-users text-primary me-2"></i>

            Residents of <%= societyName %>

        </h2>

        <p class="text-muted">

            View all registered residents in your society.

        </p>

    </div>

    <!-- =========================================
         Pending Approvals
    ========================================== -->

    <% if (isAdmin && appliedResidents.length) { %>

    <div class="card shadow border-0 rounded-4 mb-5">

        <div class="card-header bg-warning text-dark rounded-top-4">

            <h4 class="mb-0">

                <i class="fas fa-user-clock me-2"></i>

                Pending Resident Approvals

            </h4>

        </div>

        <div class="card-body">

            <form action="/approveResident" method="POST">

                <div class="row g-4">

                    <% appliedResidents.forEach(user => { %>

                    <div class="col-lg-6">

                        <div class="card border-0 shadow-sm h-100">

                            <div class="card-body">

                                <div class="d-flex justify-content-between align-items-center">

                                    <div>

                                        <h5 class="mb-1">

                                            <%= user.firstName %>

                                            <%= user.lastName %>

                                        </h5>

                                        <span class="badge bg-primary">

                                            Flat <%= user.flatNumber %>

                                        </span>

                                    </div>

                                    <div>

                                        <button

                                            class="btn btn-success me-2"

                                            type="submit"

                                            name="validate[<%= user._id %>]"

                                            value="approved">

                                            <i class="fas fa-check"></i>

                                        </button>

                                        <button

                                            class="btn btn-danger"

                                            type="submit"

                                            name="validate[<%= user._id %>]"

                                            value="declined">

                                            <i class="fas fa-times"></i>

                                        </button>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                    <% }) %>

                </div>

            </form>

        </div>

    </div>

    <% } %>

    <!-- =========================================
         Residents Grid
    ========================================== -->

    <div class="row g-4">

        <% societyResidents.forEach(resident => { %>

        <div class="col-xl-3 col-lg-4 col-md-6">

            <div class="card resident-card border-0 shadow-sm h-100">

                <div class="card-body text-center">

                    <div class="resident-avatar mb-3">

                        <% if(resident.profileImage){ %>

                        <img

                            src="<%= resident.profileImage %>"

                            class="avatar-img"

                            alt="Resident">

                        <% } else { %>

                        <div class="avatar-placeholder">

                            <i class="fas fa-user"></i>

                        </div>

                        <% } %>

                    </div>

                    <h5 class="fw-bold">

                        <%= resident.firstName %>

                        <%= resident.lastName %>

                    </h5>

                    <span class="badge bg-primary mb-3">

                        Flat <%= resident.flatNumber %>

                    </span>

                    <hr>

                    <p class="mb-2">

                        <i class="fas fa-phone text-success me-2"></i>

                        <%= resident.phoneNumber %>

                    </p>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>

<style>

.resident-card{

    border-radius:20px;

    transition:.3s;

}

.resident-card:hover{

    transform:translateY(-8px);

    box-shadow:0 18px 40px rgba(0,0,0,.15)!important;

}

.resident-avatar{

    display:flex;

    justify-content:center;

}

.avatar-img{

    width:100px;

    height:100px;

    border-radius:50%;

    object-fit:cover;

    border:4px solid #fff;

    box-shadow:0 8px 20px rgba(0,0,0,.15);

}

.avatar-placeholder{

    width:100px;

    height:100px;

    border-radius:50%;

    background:#0d6efd;

    color:#fff;

    display:flex;

    justify-content:center;

    align-items:center;

    font-size:38px;

}

.card-header{

    border:none;

}

@media(max-width:768px){

    .avatar-img,

    .avatar-placeholder{

        width:85px;

        height:85px;

    }

}

</style>

<%- include("partials/footer") %>